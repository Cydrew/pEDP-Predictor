            style="display:${isOv?'inline-block':'none'}">Reset to lit default</button>
        </div>
        <div class="comp-slider-track">
          <input type="range" id="cinp-${side}-${i}"
            class="comp-slider-input${isOv?' overridden':''}"
            min="0" max="${sliderMax}" step="${sliderStep}"
            value="${userPct}"
            oninput="onCompSlider('${side}',${i},this.value)"/>
          <div class="comp-slider-tick" style="left:${tickPct}%" title="Literature default: ${effectiveFreqPct}">
            lit
          </div>
        </div>
        <div class="comp-slider-readout">
          <span class="comp-slider-cur${isOv?' overridden':''}" id="ccur-${side}-${i}">
            ${formatPct(userPct)}${isOv?' (you)':''}
          </span>
          <span class="comp-slider-litref">Literature: ${effectiveFreqPct} &nbsp;|&nbsp; max: ${sliderMax}%</span>
        </div>
      </div>` : `
      <div style="font-size:11px;color:var(--ink-4);font-style:italic;padding:.4rem 0;border-left:2px solid var(--paper-2);padding-left:.6rem;margin:.3rem 0">
        Not quantified by published cohort data — descriptive risk only. No incidence percentage is shown because no validated rate is available, and the slider has been omitted to avoid implying false precision.
      </div>`;

    return `<div class="comp-detail-row">
      <div class="comp-detail-header">
        <span class="comp-detail-name">${c.name}${c.routeConditional?'<span style="font-size:9px;font-family:var(--mono);color:var(--accent);margin-left:6px;padding:1px 5px;background:var(--accent-light);border-radius:3px">ROUTE-DEPENDENT</span>':''}${!isQuantified?'<span style="font-size:9px;font-family:var(--mono);color:var(--ink-4);margin-left:6px;padding:1px 5px;background:var(--paper-2);border-radius:3px">QUALITATIVE</span>':''}</span>
        <span class="comp-severity ${SEV_CLASSES[c.severity]}" title="${c.sevLabel}" style="margin-left:auto"></span>
      </div>

      <div class="comp-incidence-badge" style="margin-bottom:4px">
        <span class="comp-freq ${FREQ_CLASSES[c.freq]}" style="font-size:12px;padding:3px 10px${isOv?';outline:1.5px solid #e8a020':''}">
          ${isOv ? formatPct(userPct)+' (you)' : effectiveFreqPct}
        </span>
        <span style="font-size:11px;color:var(--ink-4);font-style:italic">${c.freqLabel} — ${isQuantified ? 'published incidence' : 'descriptive label'}</span>
      </div>

      ${sliderBlock}

      <div class="comp-detail-body" style="margin-top:6px">${c.detail}</div>
      <div class="comp-detail-incidence">${c.citation}</div>
    </div>`;
  }).join('');
  return html;
}

function updateBalance() {
  updateBalanceNumbers();
  updateCompRows();

  // Invalidate detail-row cache if route has changed (affects route-conditional complications)
  const currentRoute = document.getElementById('route') ? document.getElementById('route').value : null;
  if (updateBalance._lastRoute !== currentRoute) {
    detailBuilt = false;
    updateBalance._lastRoute = currentRoute;
  }

  // Build detail cards only once (or after a full reset / route change)
  if (!detailBuilt) {
    document.getElementById('treatCompDetail').innerHTML   = buildDetailRows(TREAT_COMPS,   'treat');
    document.getElementById('notreatCompDetail').innerHTML = buildDetailRows(NOTREAT_COMPS, 'notreat');
    detailBuilt = true;
  }

  // Patient-specific amplifiers
  const base = getBaselineRisk(); // needed by amplifiers below
  const amps = [];
  const setting = document.getElementById('setting').value;
  const age = parseInt(document.getElementById('age').value) || 28;
  const bmi = parseFloat(document.getElementById('bmi').value) || 27;
  const hours = parseInt(document.getElementById('hours').value) || 1;

  if (setting === 'obstetric') {
    amps.push({ dir:'notreat', title:'Obstetric patient', desc:'Postpartum hypercoagulability amplifies CVT and PE risk from untreated PDPH. Immobility compounds DVT risk. Inability to care for newborn adds psychological harm. Urgency of treatment is higher.', cls:'amp-notreat' });
    amps.push({ dir:'notreat', title:'Bonding / breastfeeding impact', desc:'PDPH severely impairs the immediate postnatal period. Separation from newborn due to headache and hospitalisation is associated with elevated postpartum depression risk.', cls:'amp-notreat' });
  }
  if (base >= 0.60) {
    amps.push({ dir:'notreat', title:'Very high baseline risk (' + (base*100).toFixed(0) + '%)', desc:'High probability of developing PDPH means the complications of NOT treating are highly likely to materialise. The weighted harm of untreated PDPH scales directly with this probability.', cls:'amp-notreat' });
  }
  if (risks.prevPDPH) {
    amps.push({ dir:'notreat', title:'Prior PDPH history', desc:'Previous PDPH suggests the patient knows the severity of this condition and may have heightened anxiety. Prior experience also suggests potential for chronic headache recurrence.', cls:'amp-notreat' });
  }
  if (contras.coagulopathy || contras.anticoag) {
    amps.push({ dir:'treat', title:'Coagulopathy / anticoagulation', desc:'Bleeding risk amplifies procedural complications, particularly haematoma, radiculopathy from compression, and epidural abscess. This is an absolute contraindication — do not proceed.', cls:'amp-treat' });
  }
  if (contras.infection || contras.fever) {
    amps.push({ dir:'treat', title:'Active infection / fever', desc:'Bacteraemia dramatically increases risk of epidural abscess and septic meningitis from blood patch. Aseptic meningitis risk is also elevated. Strongly avoid until infection is cleared.', cls:'amp-treat' });
  }
  if (age > 50) {
    amps.push({ dir:'both', title:'Age > 50 years', desc:'Older patients have lower intrinsic PDPH risk (lower baseline). However, comorbidities may amplify both procedural complications (coagulopathy, reduced healing) and sequelae of untreated PDPH (CVT risk with atherosclerosis).', cls:'amp-neutral' });
  }
  if (bmi > 35) {
    amps.push({ dir:'both', title: 'Obesity (BMI ' + bmi.toFixed(0) + ')', desc:'High BMI reduces baseline PDPH risk (higher CSF pressure) but makes epidural blood patch technically more challenging, increasing accidental re-puncture and back pain risk. Specialist operator preferred.', cls:'amp-neutral' });
  }
  if (hours > 24) {
    amps.push({ dir:'treat', title:'Delayed presentation (>' + hours + 'h)', desc:'After 24 hours, evidence for prophylactic EBP weakens substantially. Therapeutic EBP when (and if) headache develops is the preferred strategy at this stage.', cls:'amp-treat' });
  }
  if (risks.chronHx) {
    amps.push({ dir:'notreat', title:'Chronic headache history', desc:'Patients with pre-existing headache disorders are at elevated risk of prolonged PDPH and difficulty distinguishing PDPH from baseline symptoms, potentially delaying appropriate treatment.', cls:'amp-notreat' });
  }

  if (!amps.length) {
    amps.push({ dir:'neutral', title:'No significant risk amplifiers identified', desc:'Standard risk-benefit profile for this patient. Default procedural and untreated-PDPH risk estimates apply.', cls:'amp-neutral' });
  }

  const dirLabel = { treat:'↑ Treat risk', notreat:'↑ No-treat risk', both:'↑ Both', neutral:'Neutral' };
  const dirCls = { treat:'amp-dir-treat', notreat:'amp-dir-notreat', both:'amp-dir-both', neutral:'' };
  document.getElementById('riskAmplifiers').innerHTML = amps.map(a => `
    <div class="amplifier-row">
      <div class="amp-dot ${a.cls}"></div>
      <div class="amp-body">
        <div class="amp-title">${a.title}</div>
        <div class="amp-desc">${a.desc}</div>
      </div>
      <div class="amp-direction ${dirCls[a.dir]}">${dirLabel[a.dir]}</div>
    </div>`).join('');
}

