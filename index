      <span class="inserted-topic-tag">${LIT_GROUPS.find(g=>g.id===p.suggestedTopic)?.title?.split('—')[0]?.trim() || 'User-added'}</span>
      <button class="inserted-remove-btn" onclick="removeInserted(${p._id})" title="Remove">×</button>
    </div>`).join('');
}

function rebuildTopicChips() {
  const topics = [{ id:'all', label:'All papers' }, ...LIT_GROUPS.map(g => ({ id:g.id, label:g.title.split('—')[0].trim() }))];
