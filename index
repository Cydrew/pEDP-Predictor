let xyChart = null;

function getTreatmentRiskScore() {
  // Procedural harm index 0–100
  // <40  = acceptable procedural risk
  // 40–74 = elevated risk — caution / shared decision
  // ≥75  = absolute contraindication territory — do not proceed
  let score = 14; // base: uncomplicated obstetric pEBP via existing catheter

  const needle = document.getElementById('needle').value;
  const setting = document.getElementById('setting').value;
  const bmi = parseFloat(document.getElementById('bmi').value) || 27;
  const hours = parseInt(document.getElementById('hours').value) || 1;

  // Tool scope is labour epidural with Tuohy ADP — no setting modifiers needed.
  // Tuohy gauge stratification is small (16/17/18G all carry similar procedural risk;
  // larger gauge is associated with marginally higher procedural concern).
  if (needle === 'tuohy16') score += 2;
  // 17G and 18G carry no additional score — they are the default scenario
  if (bmi > 40) score += 12;
  else if (bmi > 35) score += 7;
  else if (bmi > 30) score += 3;
  if (hours > 48) score += 8;
  else if (hours > 24) score += 4;
  if (risks.multiAttempt) score += 6;

  // Soft contraindication — elevated but not absolute
  if (contras.fever) score += 22;

  // ABSOLUTE contraindications — these push score firmly into ≥75 zone
  // Each on its own is sufficient to contraindicate
  if (contras.infection)                    score = Math.max(score, 82);
  if (contras.coagulopathy || contras.anticoag) score = Math.max(score, 78);
  if (contras.refusal)                      score = Math.max(score, 90);
  if (contras.icp)                          score = Math.max(score, 76);

  return Math.min(Math.max(score, 5), 98);
}

function getXYZone(pdphPct, treatScore) {
  // Hard override: ANY absolute contraindication → contraindicated regardless of PDPH risk
  if (hasHardContra()) {
    return {
      zone: 'contraindicated',
      label: 'Contraindicated — do not proceed regardless of PDPH risk',
      color: '#8b1a1a'
    };
  }

  if (treatScore >= 75) {
    return {
      zone: 'contraindicated',
      label: 'Contraindicated — resolve active risk factor before any neuraxial procedure',
      color: '#8b1a1a'
    };
  }

  const highPDPH  = pdphPct > 45;
  const highTreat = treatScore >= 40;

  // Per Uppal et al. 2024: pEBP is never routinely recommended — all non-contraindicated
  // positions reflect individualised shared decision, not a blanket "treat" recommendation.
  if  (highPDPH && !highTreat) return { zone:'consider',  label:'Evidence pattern favours considering pEBP — high predicted PDPH probability with acceptable procedural risk. Individualise per Uppal 2024.',  color:'#1d6b3f' };
  if  (highPDPH &&  highTreat) return { zone:'caution',   label:'Evidence pattern mixed — high predicted PDPH probability but elevated procedural risk. Conservative management with therapeutic EBP if headache develops is reasonable.', color:'#7a4a0a' };
  if (!highPDPH && !highTreat) return { zone:'wait',      label:'Evidence pattern favours watchful waiting — low predicted PDPH probability, low procedural risk. Therapeutic EBP available if symptoms develop.',  color:'#185FA5' };
  return                              { zone:'notindicated', label:'Evidence pattern does not favour pEBP — low predicted PDPH probability does not offset elevated procedural risk.',                      color:'#8b1a1a' };
}

function buildXYChart() {
  const ctx = document.getElementById('xyCanvas');
  if (!ctx) return;

  const base        = getBaselineRisk();
  const treatScore  = getTreatmentRiskScore();
  const pdphPct     = base * 100;
  const isContra    = hasHardContra() || treatScore >= 75;

  // Zone background plugin — 5 regions
  const zonePlugin = {
    id: 'zones',
    beforeDraw(chart) {
      const { ctx: c, chartArea: { left, right, top, bottom, width, height } } = chart;

      // Y thresholds (chart Y axis goes 0→100 bottom→top; canvas coords top→bottom)
      // Y=75 maps to canvas y = top + height*(1 - 75/100) = top + 0.25*height
      // Y=40 maps to canvas y = top + height*(1 - 40/100) = top + 0.60*height
      const yContra = top + height * (1 - 75/100);  // above this = contraindicated
      const yCaution= top + height * (1 - 40/100);  // above this (below yContra) = caution
      const xMid    = left + width  * 0.45;          // PDPH threshold 45%

      // ── Contraindicated band (top strip, full width) ──
      // Hatched fill
      c.save();
      c.beginPath();
      c.rect(left, top, width, yContra - top);
      c.clip();
      c.fillStyle = 'rgba(139,26,26,0.07)';
      c.fillRect(left, top, width, yContra - top);
      // diagonal hatching
      c.strokeStyle = 'rgba(139,26,26,0.12)';
      c.lineWidth = 1;
      const step = 10;
      for (let x = left - height; x < right + height; x += step) {
        c.beginPath();
        c.moveTo(x, top);
        c.lineTo(x + (yContra - top), yContra);
        c.stroke();
      }
      c.restore();
      // Label
      c.font = '500 10px "DM Mono", monospace';
      c.fillStyle = 'rgba(139,26,26,0.55)';
      c.fillText('CONTRAINDICATED', left + 6, top + 14);

      // ── Lower four quadrants (below contraindicated band) ──
      const quadZones = [
        { x:left,  y:yContra, w:xMid-left,  h:yCaution-yContra, fill:'rgba(253,232,232,0.50)', label:'Not indicated' },
        { x:xMid,  y:yContra, w:right-xMid, h:yCaution-yContra, fill:'rgba(254,243,222,0.55)', label:'Conservative preferred' },
        { x:left,  y:yCaution, w:xMid-left,  h:bottom-yCaution,  fill:'rgba(221,233,247,0.50)', label:'Watchful wait' },
        { x:xMid,  y:yCaution, w:right-xMid, h:bottom-yCaution,  fill:'rgba(223,242,232,0.65)', label:'May consider pEBP' },
      ];
      quadZones.forEach(z => {
        c.fillStyle = z.fill;
        c.fillRect(z.x, z.y, z.w, z.h);
        c.font = '500 10px "DM Mono", monospace';
        c.fillStyle = 'rgba(0,0,0,0.25)';
        c.fillText(z.label.toUpperCase(), z.x + 6, z.y + 14);
      });

      // ── Grid lines ──
      c.save();
      c.setLineDash([4, 4]);
      c.strokeStyle = 'rgba(0,0,0,0.10)';
      c.lineWidth = 1;
      // Vertical — PDPH threshold
      c.beginPath(); c.moveTo(xMid, top); c.lineTo(xMid, bottom); c.stroke();
      // Horizontal — caution threshold
      c.beginPath(); c.moveTo(left, yCaution); c.lineTo(right, yCaution); c.stroke();
      // Horizontal — contraindicated threshold (solid, slightly bolder)
      c.setLineDash([]);
      c.strokeStyle = 'rgba(139,26,26,0.25)';
      c.lineWidth = 1.5;
      c.beginPath(); c.moveTo(left, yContra); c.lineTo(right, yContra); c.stroke();
      c.restore();

      // ── Contraindicated label on right side ──
      c.save();
      c.font = '400 9px "DM Mono", monospace';
      c.fillStyle = 'rgba(139,26,26,0.50)';
      c.fillText('← treat risk ≥ 75', right - 82, yContra - 4);
      c.fillStyle = 'rgba(0,0,0,0.22)';
      c.fillText('← treat risk = 40', right - 82, yCaution - 4);
      c.restore();
    }
  };

  if (xyChart) { xyChart.destroy(); xyChart = null; }

  // Patient marker: yellow star normally, red X when contraindicated
  const patientBg     = isContra ? '#8b1a1a' : '#f5a623';
  const patientBorder = isContra ? '#5a0e0e' : '#c47d00';
  const patientStyle  = isContra ? 'circle' : 'star';
  const patientBorderW= isContra ? 3 : 2;
  const patientR      = isContra ? 16 : 14;

  xyChart = new Chart(ctx, {
    type: 'bubble',
    plugins: [zonePlugin],
    data: {
      datasets: [
        {
          label: 'Your patient',
          data: [{ x: pdphPct, y: treatScore, r: patientR }],
          backgroundColor: patientBg,
          borderColor:     patientBorder,
          borderWidth: patientBorderW,
          pointStyle: patientStyle,
          rotation: 0,
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      animation: { duration: 350 },
      layout: { padding: { top: 8, right: 8, bottom: 4, left: 4 } },
      scales: {
        x: {
          min: 0, max: 100,
          ticks: { font:{ family:"'DM Mono', monospace", size:10 }, color:'#9ca3af', callback: v => v+'%' },
          grid: { color:'rgba(0,0,0,0.04)' }
        },
        y: {
          min: 0, max: 100,
          ticks: { font:{ family:"'DM Mono', monospace", size:10 }, color:'#9ca3af' },
          grid: { color:'rgba(0,0,0,0.04)' }
        }
      },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label(c) {
              const lines = [`PDPH risk: ${pdphPct.toFixed(0)}%`, `Treatment risk score: ${treatScore.toFixed(0)}`];
              if (isContra) lines.push('⚠ Absolute contraindication present');
              return lines;
            },
            title() { return ''; }
          },
          backgroundColor: 'rgba(14,17,23,0.88)',
          bodyFont: { family:"'DM Mono', monospace", size:11 },
          padding: 10, cornerRadius: 6,
        }
      }
    }
  });

  // Verdict chip
  const zone = getXYZone(pdphPct, treatScore);
  const v = document.getElementById('xyVerdict');
  if (v) { v.textContent = zone.label; v.style.color = zone.color; }

  renderXYEvidence();
  renderXYRiskSummary();
}

function updateXYChart() {
  if (!document.getElementById('xyCanvas')) return;
  if (!xyChart) { buildXYChart(); return; }

  const base       = getBaselineRisk();
  const treatScore = getTreatmentRiskScore();
  const pdphPct    = base * 100;
  const isContra   = hasHardContra() || treatScore >= 75;

  xyChart.data.datasets[0].data            = [{ x: pdphPct, y: treatScore, r: isContra ? 16 : 14 }];
  xyChart.data.datasets[0].backgroundColor = isContra ? '#8b1a1a' : '#f5a623';
  xyChart.data.datasets[0].borderColor     = isContra ? '#5a0e0e' : '#c47d00';
  xyChart.data.datasets[0].borderWidth     = isContra ? 3 : 2;
  // Use a large filled circle for contraindication (stays visible at any chart zoom);
  // 'star' for default. Previously 'crossRot' rendered as a thin × that visually
  // disappeared at typical chart sizes — replaced with a high-contrast filled circle.
  xyChart.data.datasets[0].pointStyle      = isContra ? 'circle' : 'star';
  xyChart.update('active');

  const zone = getXYZone(pdphPct, treatScore);
  const v = document.getElementById('xyVerdict');
  if (v) { v.textContent = zone.label; v.style.color = zone.color; }

  renderXYEvidence();
  renderXYRiskSummary();
}

