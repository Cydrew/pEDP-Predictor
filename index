<script>
// ── STATE ──
const risks = { prevPDPH:false, chronHx:false, multiAttempt:false, anxious:false, nausea:false, male:false, itCatheter:false };
const contras = { infection:false, coagulopathy:false, refusal:false, icp:false, fever:false, anticoag:false };

function toggleRisk(el) {
  const k = el.dataset.key;
  risks[k] = !risks[k];
  el.classList.toggle('on', risks[k]);
  recalc();
}
function toggleContra(el) {
  const k = el.dataset.key;
  contras[k] = !contras[k];
  el.classList.toggle('on', contras[k]);
  recalc();
}
function showTab(id) {
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    b.classList.toggle('active', ['summary','balance','evidence','literature','forest','nnt','methods'][i] === id);
  });
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  if (id === 'nnt') buildNNTCharts();
  if (id === 'forest') buildForest();
  if (id === 'evidence') buildEvTable();
  if (id === 'literature') buildLiterature();
  if (id === 'balance') updateBalance();
  if (id === 'methods') buildMethods();
}

// ── CALCULATIONS ──
// Clinician-override for PDPH baseline risk (null = use model estimate)
let pdphOverride = null;

// ── MODEL METHOD TOGGLE ──
// 'multiplicative' (default): naive-Bayes-style combination of univariate ORs anchored
//   to a needle-specific base rate. Simple, transparent, but assumes independence.
// 'logit_additive': sum log-odds contributions on the logit scale, then sigmoid back.
//   Avoids compounding-to-extremes but imposes a functional form assumption.
// Neither is "correct" — they are two valid ways to combine univariate evidence when
// no validated multivariable regression exists for this population.
let modelMethod = 'multiplicative';

// Unified modifier definitions — both methods consume the same data.
// Each modifier specifies: when it applies (predicate on current inputs/state),
// its point-estimate OR, and a short label+citation for the Methods tab.
function getActiveModifiers() {
  const setting = document.getElementById('setting').value;
  const age = parseInt(document.getElementById('age').value) || 28;
  const bmi = parseFloat(document.getElementById('bmi').value) || 27;
  const mods = [];

  // Setting is fixed to 'obstetric' (labour epidural with Tuohy ADP) by tool scope —
  // no setting modifier is applied because the base rate is already obstetric-anchored.

  // Age
  if (age > 50)      mods.push({ key:'age>50', or:0.80, label:'Age > 50', src:'multiple cohorts (derived)' });
  else if (age < 25) mods.push({ key:'age<25', or:1.08, label:'Age < 25', src:'multiple cohorts (derived)' });

  // BMI
  if (bmi > 35)      mods.push({ key:'bmi>35', or:0.68, label:'BMI > 35', src:'Peralta 2015' });
  else if (bmi > 30) mods.push({ key:'bmi30-35', or:0.80, label:'BMI 30–35', src:'Peralta 2015 (interpolated)' });

  // Protective chips
  // Male-sex chip is removed from the UI in obstetric-only scope (patient is definitionally
  // female). State value remains but chip is auto-cleared in recalc().
  if (risks.itCatheter)   mods.push({ key:'itCath', or:0.82, label:'Intrathecal catheter after ADP', src:'Heesen 2019 meta-analysis' });

  // Risk chips
  if (risks.prevPDPH)     mods.push({ key:'prevPDPH', or:1.40, label:'Previous PDPH', src:'Amorim 2012 (conservative)' });
  if (risks.chronHx)      mods.push({ key:'chronHx', or:1.15, label:'Chronic headache Hx', src:'van Kooten 2008 (contextual)' });
  if (risks.multiAttempt) mods.push({ key:'multiAtt', or:1.22, label:'Multiple attempts', src:'Seeberger 1996' });
  if (risks.nausea)       mods.push({ key:'nausea', or:1.10, label:'Nausea at ADP', src:'descriptive cohort data' });

  return mods;
}

// Needle-specific base PDPH probability after recognised Tuohy ADP in obstetric setting.
// Recent prospective evidence:
//   - Choi 2003 SR (large pooled cohort): PDPH after ADP ~52%
//   - Heesen 2019 SR (n=1,653 obstetric): PDPH after ADP ~50% (control arms)
//   - Maranhao 2021 NMA: ~50–66% range across recent obstetric series
//   - Russell 2024 RCT (n=685): no significant 16G vs 18G PDPH difference
//   - Sprigge & Harper 2008 single-centre: 80% — outlier high, NOT used as anchor
// We use a SINGLE point estimate (55%) as the central anchor. Modest gauge stratification
// (16G 62%†, 17G 55%†, 18G 50%†) is provided as a directional signal — marked as derived (†)
// because Russell 2024 did not confirm the gauge gradient. The override slider is the
// escape hatch for clinicians who want to use a different anchor.
function getBaseRate() {
  const needle = document.getElementById('needle').value;
  // 16G base 0.62†, 17G 0.55 (anchor), 18G 0.50†
  return ({ tuohy16: 0.62, tuohy17: 0.55, tuohy18: 0.50 })[needle] || 0.55;
}

// Method A — multiplicative (modifier-weighted base rate). Each active modifier scales
// the probability directly. Simple and transparent; treats modifiers as independent
// proportional shifts. Can compound aggressively at the extremes.
function getRiskMultiplicative() {
  let p = getBaseRate();
  const mods = getActiveModifiers();
  for (const m of mods) p *= m.or;
  return Math.min(Math.max(p, 0.02), 0.97);
}

// Method B — logit-additive. Convert each OR to a log-odds contribution and sum on the
// logit scale, then sigmoid back. Mathematically closer to how multivariable logistic
// regressions combine effects (prevents over-aggressive compounding), but still uses
// univariate OR estimates from different source populations.
function getRiskLogitAdditive() {
  const p0 = getBaseRate();
  let logit = Math.log(p0 / (1 - p0));
  const mods = getActiveModifiers();
  for (const m of mods) logit += Math.log(m.or);
  const p = 1 / (1 + Math.exp(-logit));
  return Math.min(Math.max(p, 0.02), 0.97);
}

function getModelBaselineRisk() {
  return modelMethod === 'logit_additive' ? getRiskLogitAdditive() : getRiskMultiplicative();
}

function setModelMethod(method) {
  modelMethod = method;
  // Update toggle UI
  const multBtn = document.getElementById('methodMultBtn');
  const logitBtn = document.getElementById('methodLogitBtn');
  if (multBtn && logitBtn) {
    multBtn.classList.toggle('active', method === 'multiplicative');
    logitBtn.classList.toggle('active', method === 'logit_additive');
  }
  // Clear any override — the user is explicitly asking to see the model output
  pdphOverride = null;
  recalc();
  if (typeof updateMethodsComparison === 'function') updateMethodsComparison();
}

function getBaselineRisk() {
  return pdphOverride !== null ? pdphOverride : getModelBaselineRisk();
}

function syncSlider() {
  const model = getModelBaselineRisk();
  const modelPct = Math.round(model * 100);
  document.getElementById('modelEstLabel').textContent = modelPct + '%';

  const slider = document.getElementById('pdphSlider');
  const isOverridden = pdphOverride !== null;

  if (!isOverridden) {
    slider.value = modelPct;
    document.getElementById('pdphSliderVal').textContent = modelPct + '%';
    document.getElementById('pdphSliderVal').classList.remove('overridden');
    slider.classList.remove('overridden');
    document.getElementById('pdphResetBtn').style.display = 'none';
  } else {
    const ovPct = Math.round(pdphOverride * 100);
    slider.value = ovPct;
    document.getElementById('pdphSliderVal').textContent = ovPct + '% (override)';
    document.getElementById('pdphSliderVal').classList.add('overridden');
    slider.classList.add('overridden');
    document.getElementById('pdphResetBtn').style.display = 'block';
  }
}

function onPDPHSlider(val) {
  const model = getModelBaselineRisk();
  const modelPct = Math.round(model * 100);
  const v = parseInt(val);
  // Only set override if genuinely different from model
  if (v === modelPct) {
    pdphOverride = null;
  } else {
    pdphOverride = v / 100;
  }
  syncSlider();
  recalc();
}

function resetPDPHOverride() {
  pdphOverride = null;
  syncSlider();
  recalc();
}


function getOR() {
  const hours = parseInt(document.getElementById('hours').value) || 1;
  if (hours <= 2) return 0.13;
  if (hours <= 6) return 0.17;
  if (hours <= 12) return 0.22;
  if (hours <= 24) return 0.28;
  if (hours <= 48) return 0.38;
  return 0.52;
}

function applyOR(base, or) {
  const odds = (base / (1 - base)) * or;
  return odds / (1 + odds);
}

function hasHardContra() {
  return contras.infection || contras.coagulopathy || contras.refusal || contras.icp || contras.anticoag;
}
function hasSoftContra() { return contras.fever; }

// ── MAIN RECALC ──
function recalc() {
  // Tool scope is labour epidural Tuohy ADP — male-sex protective chip removed from UI
  // because patient is definitionally female. Force-clear any stale state.
  if (risks.male) risks.male = false;

  const base = getBaselineRisk();
  const or = getOR();
  const treated = applyOR(base, or);
  const arr = base - treated;
  const nnt = arr > 0.001 ? Math.round(1 / arr) : null;
  const hours = parseInt(document.getElementById('hours').value) || 1;
  const hardContra = hasHardContra();
  const softContra = hasSoftContra();

  // Recommendation logic — framed as evidence patterns, not verdicts.
  // The tool presents the evidence; the clinician makes the decision.
  let tier, title, body;
  if (hardContra) {
    tier = 'avoid';
    title = 'Evidence pattern: absolute contraindication present';
    body = 'One or more absolute contraindications are present. Guidelines and case literature converge against prophylactic EBP in this setting. Therapeutic EBP remains available once the contraindication has resolved. Document the contraindication and review with the patient.';
  } else if (base < 0.10) {
    tier = 'neutral';
    title = 'Evidence pattern: low predicted PDPH probability';
    body = `Predicted PDPH probability is low (${(base*100).toFixed(0)}%). At this probability the NNT is high and the procedural harm side of the balance is likely to exceed the benefit side. The evidence base favours conservative monitoring with prompt therapeutic EBP if PDPH develops.`;
  } else if (hours > 48) {
    tier = 'caution';
    title = 'Evidence pattern: window for prophylaxis has largely passed';
    body = `More than 48 hours have elapsed since ADP. The evidence for prophylactic EBP is strongest when administered within 24 hours; pooled ORs beyond 48h approach the null. If PDPH has developed, therapeutic EBP is the better-supported option. If not, watchful waiting with ready access to therapeutic EBP is evidence-supported.`;
  } else if (base >= 0.50 && hours <= 24 && !hardContra) {
    tier = 'recommend';
    title = 'Evidence pattern favours prophylactic EBP';
    body = `Predicted PDPH probability is ${(base*100).toFixed(0)}% — high. Pooled OR ${or} at ${hours}h post-ADP projects a treated probability of ${(treated*100).toFixed(0)}% (ARR ${(arr*100).toFixed(0)}%, NNT ${nnt}). Stein 2014 (18% vs 80%, p<0.0001) and Trivedi 1993 (5% vs 88%) anchor the benefit side. This pattern generally favours proceeding, subject to shared decision-making including the ~10% residual PDPH rate despite prophylaxis and procedural harms documented in the risk-balance tab.` + (softContra ? ' Soft contraindication present (fever) — address before proceeding.' : '');
  } else if (base >= 0.25) {
    tier = 'neutral';
    title = 'Evidence pattern is mixed — shared decision-making indicated';
    body = `Predicted PDPH probability is moderate (${(base*100).toFixed(0)}%). The pooled effect favours pEBP (OR ${or}; NNT ${nnt}), but heterogeneity across trials is substantial (I² 51%) and the Scavone 2004 sham-controlled RCT found no reduction in PDPH incidence, only shortened duration. In this probability range neither "proceed" nor "do not proceed" is clearly evidence-dominant. Patient preference, timing, and local expertise carry weight.`;
  } else {
    tier = 'caution';
    title = 'Evidence pattern: benefit is uncertain at this probability';
    body = `Predicted PDPH probability (${(base*100).toFixed(0)}%) sits below 25%. At this level the benefit-harm balance is not clearly favourable in the published evidence. Conservative management with immediate availability of therapeutic EBP if symptoms develop is an evidence-supported alternative.`;
  }

  // Update recommendation card
  const card = document.getElementById('recCard');
  card.className = `rec-card ${tier} animate-in`;
  void card.offsetWidth; // reflow for animation
  card.className = `rec-card ${tier} animate-in`;
  document.getElementById('recTier').textContent = { recommend:'Evidence pattern', neutral:'Evidence pattern', caution:'Evidence pattern', avoid:'Evidence pattern' }[tier];
  document.getElementById('recTitle').textContent = title;
  document.getElementById('recBody').textContent = body;

  // Update metrics
  document.getElementById('mBase').textContent = (base*100).toFixed(0)+'%';
  document.getElementById('mBase').className = `metric-val ${base>=0.5?'red':base>=0.25?'amber':'green'}`;
  document.getElementById('mBaseBar').style.width = (base*100).toFixed(0)+'%';

  document.getElementById('mTreated').textContent = (treated*100).toFixed(0)+'%';
  document.getElementById('mTreatedBar').style.width = (treated*100).toFixed(0)+'%';

  document.getElementById('mARR').textContent = (arr*100).toFixed(0)+'%';
  document.getElementById('mARRBar').style.width = Math.min(arr*200, 100).toFixed(0)+'%';

  document.getElementById('mNNT').textContent = nnt ? nnt : '—';
  document.getElementById('mNNT').className = `metric-val ${nnt&&nnt<=5?'green':nnt&&nnt<=10?'blue':nnt?'amber':''}`;

  // Contraindication list
  updateContraList();

  // Evidence basis text
  const hours_ = parseInt(document.getElementById('hours').value)||1;
  document.getElementById('evidenceBasis').innerHTML =
    `<strong>Applied OR:</strong> ${or} (timing-adjusted for ${hours_}h post-ADP). Pooled from Stein 2014, Trivedi 1993, Boonmak Cochrane 2010, Apfel SR 2010. &nbsp;
    <strong>Baseline risk model:</strong> needle gauge, setting, age, BMI, and clinical modifiers per published incidence data (Choi 2003 meta-analysis; ASA 2023 guideline). &nbsp;
    <strong>Heterogeneity note:</strong> I² = 51% — moderate. Null result from Scavone 2004 (sham-controlled, n=64) is the primary source. The timing-adjusted OR should be interpreted with caution beyond 24 hours.`;

  // Update contra status chip
  document.getElementById('contraStatus').textContent = hardContra ? 'ABSOLUTE CONTRAINDICATION' : softContra ? 'RELATIVE CONTRAINDICATION' : 'CLEAR';
  document.getElementById('contraStatus').style.color = hardContra ? 'var(--danger)' : softContra ? 'var(--warn)' : 'var(--success)';

  // Refresh balance tab if visible
  if (document.getElementById('tab-balance').classList.contains('active')) {
    updateBalanceNumbers();
    updateCompRows();
  }

  // Always refresh XY chart
  updateXYChart();

  // Keep slider in sync with model
  syncSlider();
  // Keep live comparison in Methods tab current
  if (typeof updateMethodsComparison === 'function') updateMethodsComparison();
}

function updateContraList() {
  const defs = {
    infection: { label:'Active infection', type:'hard', msg:'Epidural abscess/meningitis risk — absolute contraindication.' },
    coagulopathy: { label:'Coagulopathy', type:'hard', msg:'Elevated bleeding risk — check INR, platelets, and fibrinogen before proceeding.' },
    refusal: { label:'Patient refusal', type:'hard', msg:'Informed consent is required — respect patient autonomy.' },
    icp: { label:'Raised intracranial pressure', type:'hard', msg:'Epidural injection may worsen herniation risk.' },
    fever: { label:'Active fever >38°C', type:'soft', msg:'Relative contraindication — defer until afebrile; exclude septicaemia.' },
    anticoag: { label:'Anticoagulants active', type:'hard', msg:'Check drug, timing, and half-life. LMWH: wait ≥12h (prophylactic) or ≥24h (therapeutic).' },
  };
  let html = '';
  let any = false;
  Object.entries(defs).forEach(([k,v]) => {
    if (!contras[k]) return;
    any = true;
    const cls = v.type === 'hard' ? 'contra-hard' : 'contra-soft';
    const dot = v.type === 'hard' ? 'dot-red' : 'dot-amber';
    html += `<div class="contra-item ${cls}"><div class="contra-dot ${dot}"></div><div><strong>${v.label}:</strong> ${v.msg}</div></div>`;
  });
  if (!any) html = `<div class="contra-item contra-ok"><div class="contra-dot dot-green"></div><div><strong>No contraindications flagged.</strong> Procedural safety screen passed — standard aseptic technique and consent required.</div></div>`;
  document.getElementById('contraList').innerHTML = html;
}

// ── EVIDENCE TABLE ──
const STUDIES = [
  { author:'Stein et al.', year:2014, design:'RCT', n:109, pEBP:'18.3%', ctrl:'79.6%', or:'0.06', ci:'0.03–0.14', notes:'Obstetric; prophylactic vs therapeutic arm; strongest modern RCT', pmid:'24641638' },
  { author:'Scavone et al.', year:2004, design:'RCT', n:64, pEBP:'48%', ctrl:'56%', or:'0.73', ci:'0.28–1.92', notes:'Sham-controlled; no PDPH incidence reduction; shortened duration only', pmid:'15564951' },
  { author:'Trivedi et al.', year:1993, design:'RCT', n:74, pEBP:'5%', ctrl:'87.5%', or:'0.03', ci:'0.004–0.22', notes:'3 arms: control, saline, blood; most dramatic single-study effect', pmid:'8442966' },
  { author:'Boonmak & Boonmak', year:2010, design:'Cochrane', n:379, pEBP:'pooled', ctrl:'pooled', or:'0.11', ci:'0.02–0.64', notes:'Cochrane review; 9 studies; insufficient evidence for firm recommendation', pmid:'20091522' },
  { author:'Apfel et al.', year:2010, design:'SR', n:1264, pEBP:'pooled', ctrl:'pooled', or:'0.32', ci:'0.10–1.03', notes:'17 studies; RR 0.48 (non-RCTs), 0.32 (RCTs); systematic review', pmid:'20090833' },
  { author:'Colonna-Romano', year:1989, design:'Cohort', n:86, pEBP:'54%', ctrl:'59%', or:'0.82', ci:'0.27–2.51', notes:'Early study; no significant benefit found', pmid:'466549' },
  { author:'Sandesc et al.', year:2005, design:'RCT', n:32, pEBP:'n/a', ctrl:'n/a', or:'0.04', ci:'0.00–0.39', notes:'Therapeutic EBP vs conservative in established PDPH', pmid:'16265829' },
  { author:'Oedit et al. (BLOPP)', year:2007, design:'RCT', n:40, pEBP:'58%', ctrl:'90%', or:'0.18', ci:'0.04–0.76', notes:'Therapeutic; RR 0.64 at 24h, 0.18 at 7d; observer-blind', pmid:'17635971' },
];

// Evidence underlying the predicted PDPH probability model in Methods §1.
// Distinct from STUDIES above: these are about PDPH risk factors, not pEBP efficacy.
// PMIDs have been verified against PubMed where present; entries without pmid
// carry author-year-journal so readers can locate the source manually.
const MODIFIER_STUDIES = [
  { author:'Maranhao et al.', year:2021, design:'SR', n:'NMA', modifier:'PDPH after Tuohy ADP — anchor for base rate', effect:'~50–66% range', ci:'pooled', notes:'Network meta-analysis. Recent definitive synthesis; supports a 55% point estimate as the central anchor for 17G Tuohy ADP. Anaesthesia 2021.', pmid:'33277677' },
  { author:'Russell et al.', year:2024, design:'RCT', n:685, modifier:'16G vs 18G Tuohy gauge effect', effect:'No significant difference', ci:'—', notes:'Randomized trial in obstetric epidural placement found no significant difference in ADP rate or PDPH between 16G and 18G Tuohy needles. The basis for not over-stratifying gauge in this tool. Anaesthesia 2024.', pmid:'38847279' },
