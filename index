function removeInserted(idx) {
  const paper = USER_PAPERS[idx];
  if (!paper) return;
  USER_PAPERS.splice(idx, 1);

  // Remove from LIT_GROUPS
  for (const g of LIT_GROUPS) {
    const i = g.papers.indexOf(paper);
    if (i > -1) { g.papers.splice(i, 1); break; }
