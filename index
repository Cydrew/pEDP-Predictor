        <thead><tr><th>OR source</th><th>Timing</th><th>OR</th><th>Studies</th></tr></thead>
        <tbody>
          <tr><td>Best case (early)</td><td>&lt;6h post-ADP</td><td class="num">0.06–0.13</td><td>Stein 2014; Trivedi 1993</td></tr>
          <tr><td>Pooled (default)</td><td>6–24h post-ADP</td><td class="num">0.20</td><td>Random-effects pool of 6 studies</td></tr>
          <tr><td>Conservative</td><td>24–48h post-ADP</td><td class="num">0.32</td><td>Apfel SR/MA 2010 upper bound</td></tr>
          <tr><td>Weak / null</td><td>&gt;48h post-ADP</td><td class="num">0.50–0.82</td><td>Scavone 2004; Colonna-Romano 1989</td></tr>
        </tbody>
      </table>
      <div class="meth-caveat"><strong>Assumption.</strong> OR is treated as constant across baseline risks, which is standard in meta-analysis but is a known approximation. For a fixed OR &lt; 1, ARR and therefore NNT vary strongly with baseline risk — a patient with 90% baseline risk has a much smaller NNT than one at 20%, which is why the NNT curves on the NNT Analysis tab are not flat.</div>
    </div>

    <!-- §3 Complication burden score -->
    <div class="meth-section">
      <div class="meth-h">§3 &nbsp;Complication burden score (Y-axis of decision chart, 0–100)</div>
      <div class="meth-sub">The vertical position of your patient marker on the Cartesian decision chart.</div>
      <div class="meth-eq">
        <code>score = 14 (base)<span class="derived-marker" title="The base score of 14 is an anchor point chosen to represent the lowest-risk scenario; it is not derived from a specific cohort. Changing this number would shift the entire complication burden scale.">†</span> + Σ(modifier weights)<span class="derived-marker" title="All integer modifier weights below (+3, +6, +8, +10, +12) are clinical-judgment values, not extracted from a multivariable regression. They are intended to produce ordinal correctness (more risk → higher score) rather than calibrated absolute risk.">†</span> &nbsp;+&nbsp; contraindication floors<span class="derived-marker" title="The ≥75 absolute-contraindication floor and individual offsets (+76 to +90) are anchored on guideline-level exclusions (ASA 2023, ASRA 2018) rather than computed probabilities.">†</span></code>
      </div>
      <p style="font-size:12.5px;line-height:1.55">The base value of <strong>14</strong> represents an uncomplicated obstetric pEBP administered <em>via an existing in-situ epidural catheter</em>. This is the lowest-risk scenario in the literature: back pain 25–35%, transient radiculopathy 5–16%, failure 10–18%, serious events &lt;0.1% (Safa-Tisseront 2001 n=504; Stein 2014 n=60 pEBP arm). Modifier weights below are additive; absolute contraindications apply a <em>floor</em> at ≥75 that overrides any other computation.</p>
      <p style="font-size:12px;color:var(--ink-3);margin-top:.5rem">Full modifier table with per-row citations is documented on the Risk-Balance tab under "How the complication burden score is calculated." Summary:</p>
      <table class="meth-table">
        <thead><tr><th>Modifier type</th><th>Weight range</th><th>Examples</th></tr></thead>
        <tbody>
          <tr><td>Route / setting</td><td class="num">+0 to +10</td><td>In-situ catheter +0; non-obstetric new needle +8; diagnostic LP +10</td></tr>
          <tr><td>Needle/technique</td><td class="num">+3 to +6</td><td>20G Tuohy +3; Quincke/pencil-point requiring new pass +6</td></tr>
          <tr><td>Anatomy</td><td class="num">+3 to +8</td><td>BMI 30–35 +3; BMI &gt;35 +6; severe scoliosis +8</td></tr>
          <tr><td>Soft contraindications</td><td class="num">+6 to +12</td><td>Fever +12; platelets 80–100k +10</td></tr>
          <tr><td>Absolute contraindications</td><td class="num">floor ≥75</td><td>Bacteraemia +≥82; coagulopathy +≥78; refusal +≥90; raised ICP +≥76</td></tr>
        </tbody>
      </table>
    </div>

    <!-- §4 Decision zones -->
    <div class="meth-section">
      <div class="meth-h">§4 &nbsp;Decision zones on the Cartesian chart</div>
      <div class="meth-sub">Why the chart is divided the way it is.</div>
      <p style="font-size:12px;color:var(--ink-3);margin-bottom:.5rem;font-style:italic">
        Note: every threshold in this table is marked <span class="derived-marker" style="cursor:default">†</span> because the cut-points themselves are pragmatic boundaries — chosen to reflect where the evidence pattern qualitatively changes — rather than literature-derived constants. The values they slice (PDPH probability, complication score) are derived from literature (§1, §3); the SLICE POINTS are model decisions.
      </p>
      <table class="meth-table">
        <thead><tr><th>Zone</th><th>X (PDPH prob)</th><th>Y (complication score)</th><th>Recommendation</th></tr></thead>
        <tbody>
          <tr><td>May consider pEBP</td><td class="num">≥ 50%<span class="derived-marker" title="Threshold corresponds roughly to the point at which NNT drops below 5 at pooled OR. Pragmatic, not literature-derived.">†</span></td><td class="num">&lt; 25<span class="derived-marker" title="Score 25 is roughly the level at which baseline procedural risks have not been materially amplified. Pragmatic boundary.">†</span></td><td>RCT-supported benefit exceeds procedural harm</td></tr>
          <tr><td>Individualise</td><td class="num">25–50%<span class="derived-marker" title="Pragmatic mid-band where evidence pattern is mixed.">†</span></td><td class="num">&lt; 40<span class="derived-marker" title="Pragmatic boundary.">†</span></td><td>Shared decision; timing-dependent</td></tr>
          <tr><td>Conservative preferred</td><td class="num">≥ 25%</td><td class="num">40–60<span class="derived-marker" title="Pragmatic band where modifiers begin to materially worsen the harm side.">†</span></td><td>Elevated harm side; defer to therapeutic EBP if PDPH develops</td></tr>
          <tr><td>Watchful wait</td><td class="num">&lt; 25%<span class="derived-marker" title="Pragmatic floor below which NNT exceeds clinically reasonable values.">†</span></td><td class="num">&lt; 40<span class="derived-marker" title="Pragmatic boundary.">†</span></td><td>Low benefit + low harm; monitor</td></tr>
          <tr><td>Not indicated</td><td class="num">&lt; 25%</td><td class="num">40–74</td><td>Low benefit + elevated harm → defer</td></tr>
          <tr><td>Contraindicated</td><td class="num">any</td><td class="num">≥ 75<span class="derived-marker" title="The 75 floor for absolute contraindications anchors on guideline exclusions (ASA 2023; ASRA 2018) rather than a computed probability — guideline-derived but not a literature point estimate of risk.">†</span></td><td>Absolute exclusion floors the score; benefit cannot offset</td></tr>
        </tbody>
      </table>
      <div class="meth-note"><strong>Boundaries are pragmatic, not derived.</strong> The 50% PDPH threshold reflects the rough point at which NNT falls below 5 at pooled OR. The ≥75 contraindication floor anchors on guideline-level exclusions (ASA 2023; ASRA 2018) rather than a computed probability.</div>
    </div>

    <!-- §5 Balance scale -->
    <div class="meth-section">
      <div class="meth-h">§5 &nbsp;Risk-balance scale weighting</div>
      <div class="meth-sub">How the two-pan visualisation translates complication lists into a single "TREAT ↑ / CAUTION" verdict.</div>
      <div class="meth-eq">
        <code>for each complication c:</code><br>
        <code>&nbsp;&nbsp;effective% = user_override ?? literature_default</code><br>
        <code>&nbsp;&nbsp;contribution = baseWeight(c)<span class="derived-marker" title="Each complication's baseWeight (integer 2–14) is a clinical-judgment value reflecting its severity-by-frequency importance, not a literature-extracted coefficient. Visible in the source data as TREAT_COMPS / NOTREAT_COMPS arrays.">†</span> × effective% / literature_default%</code><br>
        <code>treatScore   = 0.7<span class="derived-marker" title="The 0.7× factor on treat-side complications is a model assumption to prevent over-counting non-independent complications. Pragmatic constant, not derived.">†</span> × Σ contributions (pEBP complications)</code><br>
        <code>notreatScore = (0.4<span class="derived-marker" title="The 0.4 floor and 0.6 slope in '(0.4 + 0.6 × P(PDPH))' are model constants reflecting that some untreated-PDPH sequelae can occur even with brief CSF leak. Not literature-derived.">†</span> + 0.6<span class="derived-marker" title="See note on the 0.4 constant — these two values together control how the untreated side scales with PDPH probability.">†</span> × P(PDPH)) × Σ contributions (PDPH sequelae)</code><br>
        <code>verdict  = f(notreatScore − treatScore)</code>
      </div>
      <p style="font-size:12.5px;line-height:1.55">The <code>(0.4 + 0.6 × P(PDPH))</code> factor reflects that untreated-PDPH sequelae only materialise if PDPH actually occurs: at P(PDPH) = 0 they are scaled to 0.4× (because rare severe outcomes like CVT can occur even briefly); at P(PDPH) = 1 they are scaled to 1.0×. The 0.7× factor on treat-side complications reflects that not every complication listed is probabilistically independent — summing raw weights would over-count.</p>
      <p style="font-size:12px;color:var(--ink-3)">Route-conditional complications (currently only "accidental dural re-puncture") use the route-adjusted effective% — see §6 below.</p>
      <table class="meth-table">
        <thead><tr><th>Verdict band</th><th>Score difference (notreat − treat)</th></tr></thead>
        <tbody>
          <tr><td>TREAT ↑↑</td><td class="num">&gt; 20<span class="derived-marker" title="Verdict-band cut-points are pragmatic; chosen to map score differences to ordinal language. Not derived from outcomes data.">†</span></td></tr>
          <tr><td>TREAT ↑</td><td class="num">8 to 20<span class="derived-marker" title="Pragmatic cut-point.">†</span></td></tr>
          <tr><td>TREAT (marginal)</td><td class="num">2 to 8<span class="derived-marker" title="Pragmatic cut-point.">†</span></td></tr>
          <tr><td>BALANCED</td><td class="num">−2 to 2<span class="derived-marker" title="Pragmatic cut-point — narrow band where the two sides are essentially indistinguishable.">†</span></td></tr>
          <tr><td>CAUTION — reassess</td><td class="num">&lt; −2<span class="derived-marker" title="Pragmatic cut-point.">†</span></td></tr>
        </tbody>
      </table>
    </div>

    <!-- §5b XY summary panel ranking -->
    <div class="meth-section">
      <div class="meth-h">§5b &nbsp;XY summary panel ranking heuristic<span class="derived-marker" title="Entire ranking heuristic in this section is model-derived; severity weights and floor values are clinical-judgment choices.">†</span></div>
      <div class="meth-sub">How the top-5 complications are chosen for the Cartesian-chart summary panels.</div>
      <p style="font-size:12.5px;line-height:1.55">The Cartesian-chart summary lists the 5 most clinically important complications on each side. Ranking by raw incidence alone would bury rare-but-critical events (sepsis &lt;0.01%) below common-but-mild ones (back pain ~30%). To prevent that, the rank is computed as:</p>
      <div class="meth-eq">
        <code>sortKey = severityWeight × max(rate%, severityFloor) × baseWeight</code>
      </div>
      <table class="meth-table">
        <thead><tr><th>Severity</th><th>Severity weight<span class="derived-marker" title="Severity weights {1, 2, 4, 6} for {mild, moderate, severe, critical} are model-imposed multipliers chosen to ensure critical events can outrank common-but-mild ones in the top-5 panel. Not derived.">†</span></th><th>Rate floor<span class="derived-marker" title="Rate floors {0.1%, 0.1%, 0.25%, 0.5%} for {mild, moderate, severe, critical} are model-imposed minimums applied during ranking only (not to incidence display). Floor values were tuned to produce clinically defensible top-5 ordering for the current complication list.">†</span></th></tr></thead>
        <tbody>
          <tr><td>Mild</td><td class="num">1</td><td class="num">0.1%</td></tr>
          <tr><td>Moderate</td><td class="num">2</td><td class="num">0.1%</td></tr>
          <tr><td>Severe</td><td class="num">4</td><td class="num">0.25%</td></tr>
          <tr><td>Critical</td><td class="num">6</td><td class="num">0.5%</td></tr>
        </tbody>
      </table>
      <p style="font-size:12px;color:var(--ink-3);margin-top:.5rem">Floors apply only to the ranking computation, not to displayed incidence percentages. A complication with literature incidence &lt;0.01% still <em>displays</em> as &lt;0.01%, but its rank position is computed using its severity-floor value to ensure it can surface in the top-5 alongside common events. This was a deliberate choice after a clinician review flagged that infectious risks were being buried below back pain in the original incidence-only ranking.</p>
    </div>

    <!-- §6 Route-conditional logic -->
    <div class="meth-section">
      <div class="meth-h">§6 &nbsp;Route-conditional complications</div>
      <div class="meth-sub">Why some complication incidences depend on how the pEBP is delivered.</div>
      <p style="font-size:12.5px;line-height:1.55">Currently one complication is route-conditional: <strong>accidental dural re-puncture during EBP</strong>. When the pEBP is administered through the <em>in-situ epidural catheter</em>, there is no second needle pass — so the probability of a re-puncture is structurally zero. When the pEBP is delivered via a <em>fresh Tuohy needle at a new interspace</em>, the published incidence is ~0.5–1% (Sprigge & Harper 1/118 ≈ 0.8%; Abouleish 1/118 ≈ 0.8%; Kokki 1/151 ≈ 0.7%; Russell 2023 narrative review).</p>
      <table class="meth-table">
        <thead><tr><th>Route</th><th>Re-puncture rate used</th><th>Displayed as</th></tr></thead>
        <tbody>
          <tr><td>In-situ epidural catheter</td><td class="num">~0%</td><td>"~0% (catheter route)"</td></tr>
          <tr><td>Fresh Tuohy, new interspace</td><td class="num">0.5–1%</td><td>"~0.5–1%"</td></tr>
          <tr><td>Unknown / not yet decided</td><td class="num">~0.3–0.7% (midpoint)</td><td>"~0.3–0.7% (route TBD)"</td></tr>
        </tbody>
      </table>
      <div class="meth-note"><strong>Why back pain and radiculopathy are not route-conditional in this tool.</strong> Published data do not cleanly separate these complications by route, and the mechanism (epidural blood injection volume) is substantially similar for both approaches. The weights are therefore held constant. This is a deliberate simplification.</div>
    </div>

    <!-- §7 Limitations -->
    <div class="meth-section">
      <div class="meth-h">§7 &nbsp;Assumptions &amp; limitations</div>
      <ul style="font-size:12.5px;line-height:1.65;padding-left:1.25rem">
        <li><strong>The pooled OR is heterogeneous.</strong> The six studies feeding the pooled estimate span OR 0.03 (Trivedi 1993) to OR 0.82 (Colonna-Romano 1989). This spread is real between-study variability, not just imprecision — see the forest plot. The "0.20" pooled point estimate should be interpreted with wide uncertainty, and the three OR scenarios on the NNT Analysis tab (0.06, 0.20, 0.32) are provided specifically to prevent over-commitment to a single number.</li>
        <li><strong>Publication bias cannot be formally assessed.</strong> With n=6 studies (below the Cochrane-recommended 10-study threshold for Egger's/Begg's tests), no formal test of publication bias is defensible. Readers should assume that small negative trials of prophylactic EBP may be under-represented in the literature and treat pooled efficacy estimates as plausibly optimistic.</li>
        <li><strong>No prospective validation.</strong> The weights, thresholds, and decision zones are literature-anchored but the composite output has not been validated against real-world clinical outcomes. The tool is shared-decision-support, not a diagnostic.</li>
        <li><strong>Risk modifiers combine multiplicatively.</strong> This is a simplification. Real-world dependencies (e.g. high BMI and multiple attempts co-occur) are not modelled.</li>
        <li><strong>Timing effect is modelled as stepwise</strong> by using different OR values for &lt;6h, 6–24h, 24–48h, &gt;48h. The true relationship is likely continuous; the stepwise approximation tracks the available stratified data.</li>
        <li><strong>Contraindication floors are categorical, not gradient.</strong> A borderline case (e.g. platelets 99k) sits on one side of a line; the tool does not grade severity within an absolute contraindication.</li>
        <li><strong>All incidence sliders are overridable.</strong> This is intentional — local experience, institutional event rates, and patient-specific factors should modify literature defaults. The ★ icon marks overridden values.</li>
      </ul>
    </div>
  `;
  document.getElementById('methodsContent').innerHTML = html;
  updateMethodsComparison();
}

// Live side-by-side comparison of both combination methods for the current patient.
// Called whenever inputs change or the Methods tab is opened.
function updateMethodsComparison() {
  const box = document.getElementById('methodsCompareBox');
  if (!box) return;
  const base = getBaseRate();
  const pMult = getRiskMultiplicative();
  const pLogit = getRiskLogitAdditive();
  const mods = getActiveModifiers();
  const activeMods = mods; // No setting-based filtering — scope is labour epidural Tuohy ADP only
  const diff = Math.abs(pMult - pLogit) * 100;

  // Detect WHY both methods agree — clamping is informationally distinct from
  // genuine math agreement. Compute the raw (unclamped) values to check.
  let rawMult = base;
  for (const m of activeMods) rawMult *= m.or;
  let rawLogit_l = Math.log(base/(1-base));
  for (const m of activeMods) rawLogit_l += Math.log(m.or);
  const rawLogit = 1/(1+Math.exp(-rawLogit_l));
  const bothFloored = pMult <= 0.0201 && pLogit <= 0.0201 && (rawMult < 0.02 || rawLogit < 0.02);
  const bothCeiling = pMult >= 0.9699 && pLogit >= 0.9699 && (rawMult > 0.97 || rawLogit > 0.97);
  const noModifiers = activeMods.length === 0;

  const diffColor = diff < 3 ? '#1d6b3f' : diff < 8 ? '#c47d00' : '#8b1a1a';
  const diffLabel = diff < 3 ? 'close agreement' : diff < 8 ? 'moderate divergence' : 'substantial divergence';

  let modsHtml = '<span style="color:var(--ink-4);font-style:italic">no active modifiers</span>';
  if (activeMods.length > 0) {
    modsHtml = activeMods.map(m => `<span style="display:inline-block;padding:1px 7px;background:${m.or<1?'#dff2e8':'#fde8e8'};border-radius:3px;font-size:11px;margin:2px 4px 2px 0;font-family:var(--mono)">${m.label} × ${m.or}</span>`).join('');
  }

  // Determine the explanatory line for why methods agree (or don't)
  let explanationHtml = '';
  if (noModifiers) {
    explanationHtml = ` Both methods reduce to the base rate when no modifiers are active — they are mathematically identical at this point.`;
  } else if (bothFloored) {
    explanationHtml = ` <strong>Both values are at the 2% floor</strong> — raw multiplicative would be ${(rawMult*100).toFixed(2)}% and raw logit would be ${(rawLogit*100).toFixed(2)}%, but the model clamps both to 0.02 (2%). The methods would actually disagree here, but the clamp masks it. Below the floor, the choice of method does not matter because neither value is precise.`;
  } else if (bothCeiling) {
    explanationHtml = ` <strong>Both values are at the 97% ceiling</strong> — raw multiplicative would be ${(rawMult*100).toFixed(1)}% and raw logit would be ${(rawLogit*100).toFixed(1)}%, but the model clamps both to 0.97 (97%). The methods would actually disagree here, but the clamp masks it. Above the ceiling, the choice of method does not matter because neither value is precise.`;
  } else if (diff < 3) {
    explanationHtml = ` Both methods produce essentially the same answer for this patient; the functional-form choice does not materially affect decision-making.`;
  } else if (diff < 8) {
    explanationHtml = ` Moderate disagreement suggests the modifiers are at values where the functional form starts to matter. Consider using the override slider with a range rather than a point estimate.`;
  } else {
    explanationHtml = ` Large disagreement indicates extreme modifier combinations where neither method is well-supported by data. Treat the predicted probability as order-of-magnitude, not point estimate.`;
  }

  box.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:.75rem">
      <div style="background:${modelMethod==='multiplicative'?'var(--accent-light)':'#fff'};border:1px solid ${modelMethod==='multiplicative'?'var(--accent)':'var(--paper-2)'};border-radius:5px;padding:.6rem">
        <div style="font-size:11px;color:var(--ink-4);font-family:var(--mono);text-transform:uppercase;letter-spacing:.03em">Method A — Multiplicative${modelMethod==='multiplicative'?' · active':''}</div>
        <div style="font-size:22px;font-weight:500;color:var(--accent);margin-top:4px">${(pMult*100).toFixed(1)}%${(bothFloored||bothCeiling)?'<span style="font-size:10px;color:#c47d00;font-family:var(--mono);margin-left:6px">clamped</span>':''}</div>
        <div style="font-family:var(--mono);font-size:10.5px;color:var(--ink-3);margin-top:4px;line-height:1.5">
          ${(base*100).toFixed(1)}% ${activeMods.map(m => `× ${m.or}`).join(' ')} = ${(rawMult*100).toFixed(1)}%${(rawMult<0.02||rawMult>0.97)?` <span style="color:#c47d00">(raw, pre-clamp)</span>`:''}
        </div>
      </div>
      <div style="background:${modelMethod==='logit_additive'?'var(--accent-light)':'#fff'};border:1px solid ${modelMethod==='logit_additive'?'var(--accent)':'var(--paper-2)'};border-radius:5px;padding:.6rem">
        <div style="font-size:11px;color:var(--ink-4);font-family:var(--mono);text-transform:uppercase;letter-spacing:.03em">Method B — Logit-additive${modelMethod==='logit_additive'?' · active':''}</div>
        <div style="font-size:22px;font-weight:500;color:var(--accent);margin-top:4px">${(pLogit*100).toFixed(1)}%${(bothFloored||bothCeiling)?'<span style="font-size:10px;color:#c47d00;font-family:var(--mono);margin-left:6px">clamped</span>':''}</div>
        <div style="font-family:var(--mono);font-size:10.5px;color:var(--ink-3);margin-top:4px;line-height:1.5">
          logit(${(base*100).toFixed(1)}%) ${activeMods.map(m => `${m.or<1?'−':'+'} ${Math.abs(Math.log(m.or)).toFixed(2)}`).join(' ')} → σ → ${(rawLogit*100).toFixed(1)}%${(rawLogit<0.02||rawLogit>0.97)?` <span style="color:#c47d00">(raw, pre-clamp)</span>`:''}
        </div>
      </div>
    </div>
    <div style="font-size:12px;color:var(--ink-3);line-height:1.55">
      <strong>Active modifiers (${activeMods.length}):</strong> ${modsHtml}
    </div>
    <div style="font-size:12px;color:${diffColor};margin-top:.5rem;font-weight:500">
      Between-method difference: ${diff.toFixed(1)} percentage points — <em>${diffLabel}</em>.${explanationHtml}
    </div>
  `;
}

// ── NNT CHARTS ──
let nntChartInst = null, timingChartInst = null;
let nntBuilt = false;

function buildNNTCharts() {
  if (nntBuilt) return;
  nntBuilt = true;

  // NNT by baseline risk
  const baseRisks = [0.10, 0.20, 0.30, 0.40, 0.50, 0.60, 0.70, 0.80, 0.90];
  const labels = baseRisks.map(r => (r*100)+'%');
  const ors = [{ v:0.06, label:'OR 0.06 — Stein/Trivedi (best case)', color:'#1a4f8a' }, { v:0.20, label:'OR 0.20 — pooled median', color:'#1d6b3f' }, { v:0.32, label:'OR 0.32 — Apfel SR upper bound', color:'#7a4a0a' }];

  function nntCalc(base, or) {
    const to = (base/(1-base))*or;
    const t = to/(1+to);
    const arr = base - t;
    return arr > 0.005 ? Math.round(1/arr) : null;
  }

  const datasets = ors.map(o => ({
    label: o.label, data: baseRisks.map(b => nntCalc(b, o.v)),
    borderColor: o.color, backgroundColor: o.color+'18', fill: false, tension:.35, pointRadius:4, pointHoverRadius:6
  }));

  nntChartInst = new Chart(document.getElementById('nntCanvas'), {
    type: 'line', data: { labels, datasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend:{display:false}, tooltip:{ callbacks:{ label:c=>`${c.dataset.label.split('—')[0]}: NNT = ${c.raw}` }}},
      scales: {
        x:{title:{display:true,text:'Baseline PDPH risk',font:{size:11,family:'DM Mono'}},grid:{color:'rgba(0,0,0,.04)'},ticks:{font:{family:'DM Mono',size:11}}},
        y:{title:{display:true,text:'NNT',font:{size:11,family:'DM Mono'}},min:0,max:50,grid:{color:'rgba(0,0,0,.04)'},ticks:{font:{family:'DM Mono',size:11}}}
      }
    }
  });

  document.getElementById('nntLegend').innerHTML = ors.map(o =>
    `<span class="legend-item"><span class="legend-swatch" style="background:${o.color}"></span>${o.label}</span>`
  ).join('');

  // Timing effect chart
  const hoursArr = [0,2,4,6,12,24,36,48,72];
  const base = getBaselineRisk();
  function orForHours(h){ if(h<=2)return .13;if(h<=6)return .17;if(h<=12)return .22;if(h<=24)return .28;if(h<=48)return .38;return .52; }
  const riskData = hoursArr.map(h => { const or=orForHours(h); const to=(base/(1-base))*or; const t=to/(1+to); return (t*100).toFixed(1); });

  timingChartInst = new Chart(document.getElementById('timingCanvas'), {
    type:'line',
    data:{ labels:hoursArr.map(h=>h+'h'), datasets:[
