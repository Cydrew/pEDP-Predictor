function autoDetectTopic(text) {
  const lower = text.toLowerCase();
  let best = 'user-added', bestScore = 0;
  for (const [topic, kws] of Object.entries(TOPIC_KEYWORDS)) {
    const score = kws.reduce((s, kw) => s + (lower.includes(kw) ? 1 : 0), 0);
    if (score > bestScore) { bestScore = score; best = topic; }
  }
  return best;
}

function extractPMID(text) {
  // PubMed URL
  const urlMatch = text.match(/pubmed\.ncbi\.nlm\.nih\.gov\/(\d{5,9})/);
  if (urlMatch) return urlMatch[1];
  // Bare PMID patterns
  const pmidMatch = text.match(/\bPMID[:\s]*(\d{5,9})\b/i) || text.match(/^(\d{5,9})$/m);
  if (pmidMatch) return pmidMatch[1];
  return null;
}

function extractDOI(text) {
  const doiMatch = text.match(/\b(10\.\d{4,}\/[^\s,;)\]"']+)/);
  return doiMatch ? doiMatch[1] : null;
}

