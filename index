async function submitInsert() {
  const raw = document.getElementById('insertInput').value.trim();
  if (!raw) { showInsertStatus('error', 'Please enter a PMID, DOI, URL, or citation text.'); return; }

  document.getElementById('insertPreview').style.display = 'none';
  setInsertBtnLoading(true);
  showInsertStatus('loading', 'Parsing citation…');

  try {
    const paper = await parseCitationWithClaude(raw);
    pendingPaper = paper;

    // Auto-detect topic if set to auto
    const topicSel = document.getElementById('insertTopic').value;
    if (topicSel === 'auto') {
      paper.topicId = autoDetectTopic((paper.title||'') + ' ' + (paper.abstract||'') + ' ' + (paper.authors||''));
    } else {
      paper.topicId = topicSel;
    }

    renderInsertPreview(paper);
    hideInsertStatus();
  } catch(e) {
    showInsertStatus('error', 'Parsing failed: ' + (e.message || 'Unknown error. Check your input and try again.'));
  } finally {
    setInsertBtnLoading(false);
  }
}

async function parseCitationWithClaude(raw) {
  const pmid = extractPMID(raw);
  const doi  = extractDOI(raw);

  const prompt = `You are a medical literature parser. Parse the following citation/identifier into structured JSON.

Input: "${raw}"

Return ONLY valid JSON with these exact fields (use null for unknown):
{
  "authors": "Last FM, Last FM, et al.",
  "title": "Full paper title.",
  "journal": "Journal Name. Year;Vol(Issue):Pages.",
  "pmid": "${pmid || 'extract if present, else null'}",
  "doi": "${doi || 'extract if present, else null'}",
  "design": "one of: RCT, Cohort, Case Report, SR/MA, Cochrane SR, Review, Case Series, Cross-sectional",
  "abstract": "2-3 sentence clinical summary: what was studied, key finding/result, clinical relevance to post-dural puncture headache or epidural blood patch. Be specific with numbers if available.",
  "year": year_as_integer_or_null
}

If input is just a PMID or DOI, infer or leave fields as null except the identifier. Do NOT include any text outside the JSON object.`;

  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 800,
      messages: [{ role: 'user', content: prompt }]
    })
  });

  if (!response.ok) throw new Error(`API error ${response.status}`);
  const data = await response.json();
  const text = data.content.map(b => b.text || '').join('').trim();
  const clean = text.replace(/^```json\s*/,'').replace(/\s*```$/,'').trim();

  let parsed;
  try { parsed = JSON.parse(clean); }
  catch(e) { throw new Error('Could not parse API response as JSON. Try providing more structured input.'); }

  // Fill in any identifiers extracted locally if API missed them
  if (!parsed.pmid && pmid) parsed.pmid = pmid;
  if (!parsed.doi && doi) parsed.doi = doi;
  parsed._raw = raw;
  return parsed;
}

