// Summaries are context-specific — generated per call based on patient inputs
function getEvidenceEntries() {
  const base      = getBaselineRisk();
  const treat     = getTreatmentRiskScore();
  const pdphPct   = base * 100;
  const zone      = getXYZone(pdphPct, treat);
  const hours     = parseInt(document.getElementById('hours').value) || 1;
  const setting   = document.getElementById('setting').value;
  const needle    = document.getElementById('needle').value;
  const bmi       = parseFloat(document.getElementById('bmi').value) || 27;
  const isHigh    = pdphPct > 45;
  const isLate    = hours > 24;
  const isObs     = setting === 'obstetric';
  const isTuohy   = ['tuohy16','tuohy17','tuohy18'].includes(needle);
  const isObese   = bmi > 35;

  const entries = [];

  // ── CONTRAINDICATED zone ──
  if (zone.zone === 'contraindicated') {
    if (contras.infection) entries.push({ paper:EV_PAPERS.dougherty1978, stance:'contra',
      summary:'Septic complications following epidural injections in bacteraemic patients establish the infection contraindication — risk of epidural abscess is prohibitive without a clean blood culture.' });
    if (contras.coagulopathy || contras.anticoag) entries.push({ paper:EV_PAPERS.moen2004, stance:'contra',
      summary:'Moen et al. documented spinal epidural haematoma risk rising sharply with coagulopathy; the severity (permanent paralysis in ~50% of undecompressed cases) makes any elective epidural injection unacceptable until haemostasis is corrected.' });
    if (contras.icp) entries.push({ paper:EV_PAPERS.villani2021, stance:'contra',
      summary:'Epidural injection acutely raises spinal epidural pressure; in the setting of raised ICP this mass effect may precipitate tentorial herniation — a mechanism-based absolute exclusion with no safe threshold.' });
    entries.push({ paper:EV_PAPERS.uppal2024, stance:'neutral',
      summary:'Uppal et al. 2024 multisociety consensus (ASRA/ESRA/SOAP/OAA) identifies active infection, coagulopathy, and raised ICP as absolute contraindications to prophylactic EBP regardless of PDPH risk.' });
    return entries;
  }

  // ── CONSIDER zone: high PDPH, low treat risk ──
  if (zone.zone === 'consider') {
    if (isTuohy && isObs) {
      entries.push({ paper:EV_PAPERS.stein2014, stance:'for',
        summary:'Stein et al. 2014 (n=109) remains the strongest RCT evidence: pEBP via the indwelling catheter reduced PDPH from 79.6% to 18.3% (p<0.0001) in obstetric patients with 17–18G Tuohy ADP — exactly this patient\'s profile.' });
      entries.push({ paper:EV_PAPERS.trivedi1993, stance:'for',
        summary:'Trivedi et al. 1993 (n=74) showed pEBP reduced PDPH from 87.5% to 5% in obstetric ADP, with the most dramatic single-study effect in the literature, supporting the benefit at very high baseline risk.' });
    }
    entries.push({ paper:EV_PAPERS.scavone2004, stance:'against',
      summary:'Scavone et al. 2004 (n=64, sham-controlled) found no reduction in PDPH incidence with pEBP — the primary source of uncertainty; notably this trial had protocolised therapeutic rescue, which may have minimised the comparator\'s headache burden.' });
    entries.push({ paper:EV_PAPERS.boonmak2010, stance:'neutral',
      summary:'Cochrane review (9 RCTs, n=379) found pEBP outperformed no treatment and conservative care, but the authors stopped short of a firm recommendation due to small sample sizes and methodological heterogeneity.' });
    entries.push({ paper:EV_PAPERS.apfel2010, stance:'neutral',
      summary:'Apfel SR/MA found RR 0.32 (0.10–1.03) across 4 RCTs — crossing unity — reflecting the genuine uncertainty: statistically non-significant on the RCT-only analysis despite clinically meaningful point estimates.' });
    entries.push({ paper:EV_PAPERS.uppal2024, stance:'neutral',
      summary:'Uppal et al. 2024 consensus states pEBP \'may be considered\' after inadvertent dural puncture but recommends against routine use, citing variable evidence; the decision must be individualised with the patient.' });
    entries.push({ paper:EV_PAPERS.guglielminotti2019, stance:'for',
      summary:'Among 1,003,803 women, PDPH carried aOR 19.0 for CVT/SDH and 39.7 for bacterial meningitis — supporting early intervention to prevent sequelae of untreated headache at this patient\'s risk level.' });
    if (isLate) entries.push({ paper:EV_PAPERS.gupta2022, stance:'against',
      summary:`EPiMAP 2022 found EBP administered <4h post-ADP associated with 3× higher failure rate; at ${hours}h the prophylactic window is narrowing and therapeutic EBP for established PDPH may be more effective.` });
    return entries;
  }

  // ── CAUTION zone: high PDPH, elevated treat risk ──
  if (zone.zone === 'caution') {
    entries.push({ paper:EV_PAPERS.safa2001, stance:'neutral',
      summary:'Safa-Tisseront 2001 (n=504) found EBP success 75% overall; failure was more likely with technically difficult access — matching this patient\'s elevated procedural risk, supporting conservative management first and therapeutic EBP if needed.' });
    entries.push({ paper:EV_PAPERS.russell2019, stance:'neutral',
      summary:'OAA guidelines 2019 recommend that in the presence of risk factors elevating procedural difficulty, conservative management with ready access to therapeutic EBP is an equally defensible strategy to prophylactic EBP.' });
    entries.push({ paper:EV_PAPERS.guglielminotti2019, stance:'for',
      summary:'The severity of untreated PDPH sequelae (aOR 19.0 for CVT/SDH) still argues for not simply observing at this PDPH risk level — the balance is between the elevated procedural burden and serious untreated headache risks.' });
    if (isObese) entries.push({ paper:EV_PAPERS.peralta2015, stance:'neutral',
      summary:`Peralta et al. found increasing BMI significantly reduces PDPH incidence — at BMI ${bmi.toFixed(0)} the baseline risk is attenuated, which further weakens the case for prophylactic EBP here versus watchful waiting.` });
    if (contras.fever) entries.push({ paper:EV_PAPERS.dougherty1978, stance:'contra',
      summary:'Fever raises concern for occult bacteraemia; Dougherty & Fraser document that epidural injection in the setting of infection risks abscess formation — defer pEBP until afebrile and bacteraemia excluded.' });
    if (isLate) entries.push({ paper:EV_PAPERS.gupta2022, stance:'against',
      summary:`EPiMAP 2022 identified early EBP (<4h) as a risk factor for failure; at ${hours}h post-ADP, therapeutic EBP when and if headache develops is more efficient and evidence-based than prophylaxis.` });
    return entries;
  }

  // ── WATCHFUL WAIT zone: low PDPH, low treat risk ──
  if (zone.zone === 'wait') {
    entries.push({ paper:EV_PAPERS.choi2003, stance:'neutral',
      summary:`Choi et al. meta-analysis (n=11,536) quantified PDPH incidence by needle type — at this patient\'s baseline risk of ~${pdphPct.toFixed(0)}%, the majority will not develop headache, making prophylaxis mathematically unattractive.` });
    entries.push({ paper:EV_PAPERS.boonmak2010, stance:'against',
      summary:'Cochrane 2010 found insufficient evidence to recommend prophylactic EBP over conservative management even in higher-risk populations — at low baseline risk the NNT rises further and the recommendation against routine use strengthens.' });
    entries.push({ paper:EV_PAPERS.uppal2024, stance:'against',
      summary:'Uppal et al. 2024 consensus explicitly advises against routine prophylactic EBP, noting variable incidence of PDPH and the risk of unnecessary procedural harm — directly supporting watchful waiting at this patient\'s risk profile.' });
    entries.push({ paper:EV_PAPERS.scavone2004, stance:'against',
      summary:'The sham-controlled Scavone 2004 RCT found no PDPH incidence reduction with pEBP, indicating that even motivated patients at moderate risk may gain nothing beyond symptom duration shortening.' });
    entries.push({ paper:EV_PAPERS.russell2019, stance:'neutral',
      summary:'OAA guidelines endorse conservative management (hydration, caffeine, analgesics, antiemetics) with a low threshold for therapeutic EBP at symptom onset — the appropriate strategy when baseline PDPH risk is low.' });
    return entries;
  }

  // ── NOT INDICATED zone: low PDPH, elevated treat risk ──
  if (zone.zone === 'notindicated') {
    entries.push({ paper:EV_PAPERS.uppal2024, stance:'against',
      summary:'Uppal et al. 2024 consensus recommends against routine prophylactic EBP — at low PDPH probability with elevated procedural risk, the benefit-to-harm ratio decisively favours conservative management.' });
    entries.push({ paper:EV_PAPERS.choi2003, stance:'neutral',
      summary:`Choi meta-analysis establishes this patient\'s baseline PDPH risk at ~${pdphPct.toFixed(0)}% — below the threshold where procedural intervention would be NNT-efficient against its complication profile.` });
    if (contras.fever) entries.push({ paper:EV_PAPERS.dougherty1978, stance:'contra',
      summary:'Dougherty & Fraser established that fever raises risk of infective epidural complications — the combination of low PDPH benefit and elevated infectious risk makes pEBP clearly inadvisable.' });
    if (isObese) entries.push({ paper:EV_PAPERS.vercauteren2009, stance:'against',
      summary:'Vercauteren et al. documented severe complications from large-volume EBPs in technically difficult cases including spinal SDH; obesity increases procedural difficulty and complication risk.' });
    entries.push({ paper:EV_PAPERS.agerson2012, stance:'neutral',
      summary:'Agerson & Scavone review concludes there is insufficient evidence to support prophylactic EBP as a routine procedure — a position reinforced when low baseline PDPH risk further diminishes the expected benefit.' });
    return entries;
  }

  return entries;
}

function renderXYEvidence() {
  const el = document.getElementById('xyEvidence');
  if (!el) return;

  const entries = getEvidenceEntries();
  if (!entries.length) { el.innerHTML = ''; return; }

  const stanceLabel = { for:'Supports pEBP', against:'Against pEBP', neutral:'Context', contra:'Contraindication' };
  const stanceCls   = { for:'stance-for', against:'stance-against', neutral:'stance-neutral', contra:'stance-contra' };

  el.innerHTML = `<div class="xy-evidence-header">Supporting literature for this patient position</div>` +
    entries.map(e => `
      <div class="xy-ev-row">
        <span class="xy-ev-stance ${stanceCls[e.stance]}">${stanceLabel[e.stance]}</span>
        <div class="xy-ev-body">
          <div class="xy-ev-title">${e.paper.authors} ${e.paper.year} — ${e.paper.title}</div>
          <div class="xy-ev-summary">${e.summary}</div>
        </div>
        <a class="xy-ev-link" href="https://pubmed.ncbi.nlm.nih.gov/${e.paper.pmid}/" target="_blank" rel="noopener">PMID ${e.paper.pmid}</a>
      </div>`).join('');
}

function renderXYRiskSummary() {
  const el = document.getElementById('xyRiskSummary');
  if (!el) return;

  // Treat side — top 5 by effective weighted incidence
  function pctClass(v) { return v > 5 ? 'high' : v > 0.5 ? 'mid' : 'low'; }

  function buildPanel(comps, side, title, panelCls) {
    // Clinical importance ranking — not raw incidence. Multiplies severity weight by the
    // EFFECTIVE rate (with a small floor for very-rare-but-critical events so they remain
    // visible). Otherwise sepsis (<0.01%) and similar critical risks get sorted off the
    // top-5 by common-but-mild events like backache. This preserves clinical priority.
    const SEVERITY_WEIGHT = { mild: 1, moderate: 2, severe: 4, critical: 6 };
    const rows = comps.map((c, i) => {
      const litPct  = parseLitPct(c.freqPct);
      const sevW    = SEVERITY_WEIGHT[c.severity] || 1;
      if (litPct === null) {
        // Non-quantifiable — rank by severity alone
        return { name: c.name, pct: -1, display: 'qualitative', isOv: false, sev: c.severity, sortKey: sevW * 0.5 * c.baseWeight };
      }
      const userPct = compWeights[side][i] ?? litPct;
      const isOv    = compWeights[side][i] !== null;
      const display = userPct < 0.01 ? '<0.01%' : userPct < 0.1 ? userPct.toFixed(2)+'%' : userPct < 1 ? userPct.toFixed(1)+'%' : userPct.toFixed(0)+'%';
      // Effective rate floor for critical/severe events: even at 0.01%, multiply by severity
      // weight and baseWeight so they can outrank a common-but-mild event. Floor prevents
      // 0.001%×6 = 0.006 from being negligible — gives clinically important events a chance
      // to surface in the top-5 even when their absolute rate is very low.
      const floor = c.severity === 'critical' ? 0.5 : c.severity === 'severe' ? 0.25 : 0.1;
      const effectiveRate = Math.max(userPct, floor);
      return { name: c.name, pct: userPct, display, isOv, sev: c.severity, sortKey: sevW * effectiveRate * c.baseWeight };
    }).sort((a, b) => b.sortKey - a.sortKey).slice(0, 5);

    return `<div class="xy-summary-panel ${panelCls}">
      <div class="xy-summary-title">${title}</div>
      ${rows.map(r => `
        <div class="xy-summary-item">
          <span class="xy-summary-comp">${r.name}${r.isOv ? ' <span style="color:#c47d00;font-size:9px">★</span>' : ''}</span>
          <span class="xy-summary-pct ${pctClass(r.pct)}">${r.display}</span>
        </div>`).join('')}
    </div>`;
  }

  el.innerHTML =
    buildPanel(TREAT_COMPS,   'treat',   'pEBP procedural risks',        'treat-panel') +
    buildPanel(NOTREAT_COMPS, 'notreat', 'Untreated PDPH consequences',  'notreat-panel');
}

