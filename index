  // Remove empty user-added group
  const uaIdx = LIT_GROUPS.findIndex(g => g.id === 'user-added' && g.papers.length === 0);
  if (uaIdx > -1) LIT_GROUPS.splice(uaIdx, 1);

  rebuildTopicFilters();
