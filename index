const FREQ_CLASSES = { common:'freq-common', uncommon:'freq-uncommon', rare:'freq-rare', veryrare:'freq-veryrare' };
const SEV_CLASSES = { mild:'sev-mild', moderate:'sev-moderate', severe:'sev-severe', critical:'sev-critical' };

// ── COMPLICATION WEIGHT STATE ──
// null = use literature default; number = clinician override (as %)
const compWeights = {
  treat:   TREAT_COMPS.map(() => null),
  notreat: NOTREAT_COMPS.map(() => null),
};

// ── DERIVED-PARAMETER MARKER ──
// Returns a superscript dagger with a hover tooltip. Used to flag any value in the
// UI that is NOT a direct literature point estimate — including: interpolated coefficients,
// conservative downgrades, judgment-call weights, decision-zone thresholds, balance-scale
// constants, and functional-form assumptions. Honest disclosure beats hidden assumptions.
function derivedMark(reason) {
  const r = reason || 'Model-derived parameter — not a direct literature point estimate. Hover for category.';
  return `<span class="derived-marker" title="${r.replace(/"/g,'&quot;')}">†</span>`;
}

function parseLitPct(freqPct) {
  // Convert freqPct string to numeric midpoint value (as a %).
  // e.g. '~25–35%' → 30, '<0.05%' → 0.025, '~9–14% excess' → 11.5
  // For non-quantifiable entries (descriptive labels, aOR statements without absolute %),
  // returns null — callers must handle null explicitly. Previously this defaulted to 1,
  // which silently inserted spurious 1% values into the balance score.
  if (!freqPct) return null;
  let s = String(freqPct).replace(/~/g,'').replace(/%/g,'').replace(/\s/g,'');
  // Range form: optional leading non-numeric and suffix non-numeric
  const rangeMatch = s.match(/^([0-9.]+)–([0-9.]+)/);
  if (rangeMatch) {
    const lo = parseFloat(rangeMatch[1]);
    const hi = parseFloat(rangeMatch[2]);
    if (!isNaN(lo) && !isNaN(hi)) return (lo + hi) / 2;
  }
  if (s.startsWith('<')) { const n = parseFloat(s.slice(1)); return isNaN(n) ? null : n/2; }
  if (s.startsWith('>')) { const n = parseFloat(s.slice(1)); return isNaN(n) ? null : n*1.5; }
  // Single number — must consume the entire numeric prefix and have nothing meaningful after
  const numMatch = s.match(/^([0-9.]+)$/);
  if (numMatch) {
    const n = parseFloat(numMatch[1]);
    return isNaN(n) ? null : n;
  }
  return null;
}

// Route-aware incidence resolver — for complications whose rate differs by pEBP route.
// Currently applies to "Accidental dural re-puncture": ~0% via catheter, 0.5–1% via fresh needle.
function getRouteAdjustedFreqPct(comp) {
  if (!comp.routeConditional) return comp.freqPct;
  const routeEl = document.getElementById('route');
  const route = routeEl ? routeEl.value : 'catheter';
  if (comp.name === 'Accidental dural re-puncture') {
    if (route === 'catheter') return '~0% (catheter route)';
    if (route === 'needle')   return '~0.5–1%';
    return '~0.3–0.7% (route TBD)';
  }
  return comp.freqPct;
}

function getSliderMax(litPct) {
  if (litPct < 0.1)  return 1;
  if (litPct < 1)    return 5;
  if (litPct < 10)   return 30;
  if (litPct < 50)   return 80;
  return 100;
}
function getSliderStep(litPct) {
  return litPct < 1 ? 0.01 : litPct < 5 ? 0.1 : 0.5;
}
function getEffectivePct(comp, side, i) {
  const ov = compWeights[side][i];
  if (ov !== null) return ov;
  const lit = parseLitPct(getRouteAdjustedFreqPct(comp));
  return lit; // may be null for nonQuantifiable entries — callers must check
}
function formatPct(v) {
  return v < 0.1 ? v.toFixed(2)+'%' : v < 1 ? v.toFixed(1)+'%' : v.toFixed(1)+'%';
}

function onCompSlider(side, i, val) {
  const litPct = parseLitPct((side==='treat'?TREAT_COMPS:NOTREAT_COMPS)[i].freqPct);
  if (litPct === null) return; // non-quantifiable; no slider should exist
  const v = parseFloat(val);
  compWeights[side][i] = Math.abs(v - litPct) < 0.001 ? null : v;
  // Update the specific slider UI without full rebuild
  const sec   = document.getElementById(`csec-${side}-${i}`);
  const cur   = document.getElementById(`ccur-${side}-${i}`);
  const rbtn  = document.getElementById(`crst-${side}-${i}`);
  const input = document.getElementById(`cinp-${side}-${i}`);
  const isOv  = compWeights[side][i] !== null;
  if (sec)  sec.classList.toggle('overridden', isOv);
  if (cur)  { cur.textContent = formatPct(v) + (isOv ? ' (you)' : ''); cur.classList.toggle('overridden', isOv); }
  if (rbtn) rbtn.style.display = isOv ? 'inline-block' : 'none';
  if (input) input.classList.toggle('overridden', isOv);
  updateCompRows();
  updateBalanceNumbers();
  renderXYRiskSummary();
}

function resetCompSlider(side, i) {
  compWeights[side][i] = null;
  const litPct = parseLitPct((side==='treat'?TREAT_COMPS:NOTREAT_COMPS)[i].freqPct);
  if (litPct === null) return; // non-quantifiable; no slider exists to reset
  const sec   = document.getElementById(`csec-${side}-${i}`);
  const cur   = document.getElementById(`ccur-${side}-${i}`);
  const rbtn  = document.getElementById(`crst-${side}-${i}`);
  const input = document.getElementById(`cinp-${side}-${i}`);
  if (sec)  sec.classList.remove('overridden');
  if (cur)  { cur.textContent = formatPct(litPct); cur.classList.remove('overridden'); }
  if (rbtn) rbtn.style.display = 'none';
  if (input) { input.value = litPct; input.classList.remove('overridden'); }
  updateCompRows();
  updateBalanceNumbers();
  renderXYRiskSummary();
}

function resetAllCompSliders() {
  compWeights.treat.fill(null);
  compWeights.notreat.fill(null);
  // Rebuild detail cards to reflect reset state
  detailBuilt = false;
  updateBalance();
}

function computeBalanceScores(base) {
  let treatScore = 0;
  TREAT_COMPS.forEach((c, i) => {
    const litPct = parseLitPct(getRouteAdjustedFreqPct(c));
    if (litPct === null) {
      // Non-quantifiable risk — count baseWeight at 0.5× to acknowledge presence
      // without pretending to know magnitude. User cannot override (no slider).
      treatScore += c.baseWeight * 0.5;
      return;
    }
    const userPct = compWeights.treat[i] ?? litPct;
    const scale = litPct > 0 ? userPct / litPct : 1;
    treatScore += c.baseWeight * scale;
  });

  let notreatScore = 0;
  NOTREAT_COMPS.forEach((c, i) => {
    const litPct = parseLitPct(c.freqPct);
    if (litPct === null) {
      notreatScore += c.baseWeight * 0.5;
      return;
    }
    const userPct = compWeights.notreat[i] ?? litPct;
    const scale = litPct > 0 ? userPct / litPct : 1;
    notreatScore += c.baseWeight * scale;
  });

  const pdphLikely = base;
  const notreatScoreAdjusted = Math.round(notreatScore * (0.4 + 0.6 * pdphLikely));
  const treatScoreAdjusted   = Math.round(treatScore * 0.7);
  return { treat: treatScoreAdjusted, notreat: notreatScoreAdjusted };
}

function updateBalanceNumbers() {
  const base = getBaselineRisk();
  const { treat, notreat } = computeBalanceScores(base);
  const maxScore = Math.max(treat, notreat, 1);
  const diff = notreat - treat;

  let verdict, verdictColor;
  if (diff > 20)      { verdict='TREAT ↑↑';          verdictColor='var(--success)'; }
  else if (diff > 8)  { verdict='TREAT ↑';            verdictColor='var(--success)'; }
  else if (diff > 2)  { verdict='TREAT (marginal)';   verdictColor='var(--warn)'; }
  else if (diff > -2) { verdict='BALANCED';            verdictColor='var(--ink-3)'; }
  else                { verdict='CAUTION — reassess'; verdictColor='var(--danger)'; }

  document.getElementById('scaleVerdict').textContent = verdict;
  document.getElementById('scaleVerdict').style.color = verdictColor;
  document.getElementById('treatScore').textContent   = treat;
  document.getElementById('notreatScore').textContent = notreat;
  document.getElementById('treatBar').style.width     = (treat/maxScore*100).toFixed(0)+'%';
  document.getElementById('notreatBar').style.width   = (notreat/maxScore*100).toFixed(0)+'%';
  document.getElementById('fulcrumNeedle').style.transform = `rotate(${Math.max(-35,Math.min(35,diff*1.2))}deg)`;
  document.getElementById('scaleTreat').className    = 'scale-side scale-treat'  + (notreat>treat?' winner':notreat<treat?' loser':'');
  document.getElementById('scaleNotreat').className  = 'scale-side scale-notreat'+ (treat>notreat?' winner':treat<notreat?' loser':'');
}

function updateCompRows() {
  function buildCompRows(comps, side) {
    return comps.map((c, i) => {
      const eff = getEffectivePct(c, side, i);
      const isOv = compWeights[side][i] !== null;
      const displayPct = (eff === null) ? '<span style="font-style:italic;font-size:10px">qual.</span>' : formatPct(eff);
      return `<div class="comp-row">
        <span class="comp-freq ${FREQ_CLASSES[c.freq]}" title="${c.freqLabel}" style="${isOv?'outline:1.5px solid #e8a020;':''}">${displayPct}</span>
        <span class="comp-name">${c.name}${isOv?'<span style="font-size:9px;color:#c47d00;font-family:var(--mono);margin-left:4px">★</span>':''}</span>
        <span class="comp-severity ${SEV_CLASSES[c.severity]}" title="${c.sevLabel}"></span>
      </div>`;
    }).join('');
  }
  document.getElementById('treatComps').innerHTML   = buildCompRows(TREAT_COMPS,   'treat');
  document.getElementById('notreatComps').innerHTML = buildCompRows(NOTREAT_COMPS, 'notreat');
}

let detailBuilt = false;

function buildDetailRows(comps, side) {
  const hasAnyOverride = compWeights[side].some(v => v !== null);
  let html = `<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem">
    <span style="font-size:11px;color:var(--ink-4);font-family:var(--mono)">DRAG SLIDERS TO ADJUST YOUR CLINICAL ESTIMATE</span>
    ${hasAnyOverride ? `<button class="comp-weight-reset-all" onclick="resetAllCompSliders()">Reset all to defaults</button>` : ''}
  </div>`;

  html += comps.map((c, i) => {
    const effectiveFreqPct = getRouteAdjustedFreqPct(c);
    const litPct  = parseLitPct(effectiveFreqPct);
    const isQuantified = litPct !== null;
    const userPct = isQuantified ? (compWeights[side][i] ?? litPct) : null;
    const isOv    = compWeights[side][i] !== null;
    const sliderMax  = isQuantified ? getSliderMax(litPct) : 100;
    const sliderStep = isQuantified ? getSliderStep(litPct) : 1;
    const tickPct    = isQuantified ? Math.min(99, (litPct / sliderMax * 100)).toFixed(1) : '0';

    const sliderBlock = isQuantified ? `
      <div class="comp-slider-section${isOv?' overridden':''}" id="csec-${side}-${i}">
