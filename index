function detectInputType(raw) {
  const t = raw.trim();
  if (/^https?:\/\/(www\.)?pubmed\.ncbi\.nlm\.nih\.gov\/(\d+)/i.test(t)) return { type:'url', pmid: t.match(/\/(\d+)\/?$/)[1] };
  if (/^https?:\/\/doi\.org\//i.test(t)) return { type:'doi', doi: t.replace(/^https?:\/\/doi\.org\//i,'') };
  if (/^(PMID:?\s*)?(\d{7,8})$/i.test(t)) return { type:'pmid', pmid: t.replace(/^PMID:?\s*/i,'').trim() };
  if (/^10\.\d{4,}\/\S+$/.test(t)) return { type:'doi', doi: t };
  return { type:'text', text: t };
}

function showStatus(msg, cls) {
  const el = document.getElementById('insertStatus');
  el.style.display = 'flex';
  el.className = 'insert-status ' + cls;
  el.innerHTML = cls === 'loading'
    ? `<div class="spinner"></div>${msg}`
    : `<svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="${cls==='success'?'M2 7l3.5 3.5 6.5-6.5':'M2 2l10 10M12 2L2 12'}"/></svg>${msg}`;
}

function hideStatus() { document.getElementById('insertStatus').style.display = 'none'; }
function hidePreview() { document.getElementById('insertPreview').style.display = 'none'; pendingParsed = null; }

function setBtnLoading(loading) {
  const btn = document.getElementById('insertBtn');
  const lbl = document.getElementById('insertBtnLabel');
  const ico = document.getElementById('insertBtnIcon');
  btn.disabled = loading;
  if (loading) {
    lbl.textContent = 'Parsing…';
    ico.innerHTML = '';
    const s = document.createElement('div'); s.className = 'spinner'; s.style.borderColor = 'rgba(255,255,255,.5)'; s.style.borderTopColor = 'transparent';
    ico.appendChild(s);
  } else {
    lbl.innerHTML = 'Parse &amp; add';
    ico.innerHTML = `<svg width="15" height="15" viewBox="0 0 15 15" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 7.5h11M9 3l4 4.5L9 12"/></svg>`;
  }
}

async function submitInsert() {
  const raw = document.getElementById('insertInput').value.trim();
  if (!raw) { showStatus('Please enter a PMID, DOI, URL, or citation text.', 'error'); return; }

  hidePreview();
  setBtnLoading(true);
  showStatus('Parsing citation — sending to Claude…', 'loading');

  const detected = detectInputType(raw);
  const topicSel = document.getElementById('insertTopic').value;

  // Build prompt for the API
  const systemPrompt = `You are a medical literature parser for a clinical decision support tool about prophylactic epidural blood patches (pEBP) and post-dural puncture headache (PDPH).

Extract structured citation data from the input and respond ONLY with a valid JSON object — no markdown fences, no preamble.

JSON schema:
{
  "authors": "Full author list as string",
  "title": "Full paper title",
  "journal": "Journal name. Year;Volume(Issue):Pages.",
  "pmid": "PubMed ID if known or derivable, else null",
  "doi": "DOI string only (no https://doi.org/ prefix), else null",
  "design": one of ["RCT","Cohort","Case Report","SR/MA","Cochrane SR","Review","Case Series","Case Report+SR","Guideline"],
  "abstract": "2-3 sentence plain-English clinical summary: what was studied, key finding, and clinical relevance to PDPH/EBP",
  "suggestedTopic": one of ["pebp-rcts","pebp-sr","therapeutic-ebp","complications-ebp","complications-pdph","cn-palsy","treatment-alternatives","user-added"],
  "cochrane": true or false
}

If the input is just a PMID or DOI and you cannot infer full details, fill what you can and leave unknown fields null. Never invent data. For suggestedTopic, use the paper's subject matter to pick the best fit.`;

  const userMsg = detected.type === 'pmid'
    ? `PMID: ${detected.pmid}\nPlease extract/infer citation details for this PubMed paper about PDPH or epidural blood patch.`
    : detected.type === 'doi'
    ? `DOI: ${detected.doi}\nPlease extract/infer citation details for this paper about PDPH or epidural blood patch.`
    : detected.type === 'url'
    ? `PubMed URL: ${raw}\nPMID: ${detected.pmid}\nPlease extract/infer citation details for this PubMed paper about PDPH or epidural blood patch.`
    : `Raw citation/abstract text:\n\n${raw}\n\nPlease parse and structure this citation.`;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: 'user', content: userMsg }]
      })
    });

    if (!response.ok) {
      const err = await response.json().catch(() => ({}));
      throw new Error(err.error?.message || `API error ${response.status}`);
    }

    const data = await response.json();
    const text = data.content.map(b => b.text || '').join('').trim();

    // Strip any accidental markdown fences
    const clean = text.replace(/^```(?:json)?\s*/i,'').replace(/\s*```$/,'').trim();
    const parsed = JSON.parse(clean);

    // Apply topic override if user selected one
    if (topicSel !== 'auto') parsed.suggestedTopic = topicSel;
    if (!parsed.suggestedTopic) parsed.suggestedTopic = 'user-added';

    pendingParsed = parsed;
    hideStatus();
    showPreview(parsed);

  } catch (err) {
    showStatus(`Parsing failed: ${err.message}. Try pasting more complete citation text.`, 'error');
  } finally {
    setBtnLoading(false);
  }
}

function showPreview(p) {
  const pmUrl = p.pmid ? `https://pubmed.ncbi.nlm.nih.gov/${p.pmid}/` : null;
  const doiUrl = p.doi ? `https://doi.org/${p.doi}` : null;
  const badge = (DESIGN_COLORS && DESIGN_COLORS[p.design]) || 'badge-cohort';
  const groupLabel = LIT_GROUPS.find(g => g.id === p.suggestedTopic)?.title || 'User-added papers';

  document.getElementById('insertPreviewCard').innerHTML = `
    <div class="lit-body">
      <div class="lit-authors">${p.authors || '<em style="color:var(--ink-4)">Authors not detected</em>'}</div>
      <div class="lit-title">${p.title || '<em style="color:var(--ink-4)">Title not detected</em>'}</div>
      <div class="lit-journal">${p.journal || ''}&nbsp;<span class="lit-tag ${badge}">${p.design || 'Unknown'}</span></div>
      <div style="font-size:12px;color:var(--ink-3);margin-top:3px;line-height:1.55">${p.abstract || '<em>No summary generated</em>'}</div>
      <div class="lit-links">
        ${pmUrl ? `<a class="lit-link lit-link-pm" href="${pmUrl}" target="_blank" rel="noopener">${EXTERNAL_ICON} PubMed ${p.pmid}</a>` : ''}
        ${doiUrl ? `<a class="lit-link lit-link-doi" href="${doiUrl}" target="_blank" rel="noopener">${EXTERNAL_ICON} DOI</a>` : ''}
      </div>
      <div style="margin-top:.5rem;font-size:11px;font-family:var(--mono);color:var(--accent)">→ Will be added to: ${groupLabel}</div>
    </div>`;
  document.getElementById('insertPreview').style.display = 'block';
  document.getElementById('insertPreview').scrollIntoView({ behavior:'smooth', block:'nearest' });
}

function confirmInsert() {
  if (!pendingParsed) return;
  const p = pendingParsed;

  // Find or create the target group
  const targetId = p.suggestedTopic || 'user-added';
  let group = LIT_GROUPS.find(g => g.id === targetId);
  if (!group) {
    group = { id:'user-added', title:'User-added papers', icon:'⬡', papers:[] };
    LIT_GROUPS.push(group);
  }
  group.papers.push(p);

  // Track in session state
  const sessionEntry = { ...p, _id: Date.now(), _group: group.title };
  insertedPapers.push(sessionEntry);

  // Refresh the grouped view
  renderGroups();

  // Update topic filter chips (new group may have appeared)
  rebuildTopicChips();

  // Update query panel count
  const totalPapers = LIT_GROUPS.reduce((s,g) => s + g.papers.length, 0);
  const countEl = document.getElementById('queryCount');
  if (countEl) countEl.textContent = `${SEARCH_QUERIES.length} queries · ${totalPapers} papers`;

  // Show inserted papers list
  renderInsertedList();

  // Show counter badge
  const counter = document.getElementById('insertCounter');
  counter.style.display = 'block';
  document.getElementById('insertCountNum').textContent = insertedPapers.length;

  // Show success, reset input
  showStatus(`Added to "${group.title}". It now appears in the grouped list above.`, 'success');
  document.getElementById('insertInput').value = '';
  document.getElementById('insertPreview').style.display = 'none';
  pendingParsed = null;

  setTimeout(hideStatus, 4000);
}

function cancelInsert() {
  hidePreview();
  hideStatus();
  document.getElementById('insertInput').focus();
}

function removeInserted(id) {
  const entry = insertedPapers.find(p => p._id === id);
  if (!entry) return;

  // Remove from LIT_GROUPS
  const group = LIT_GROUPS.find(g => g.id === entry.suggestedTopic || g.title === entry._group);
  if (group) {
    const idx = group.papers.findIndex(p => p.pmid === entry.pmid && p.title === entry.title);
    if (idx > -1) group.papers.splice(idx, 1);
  }

  // Remove from session
  insertedPapers = insertedPapers.filter(p => p._id !== id);

  // Refresh UI
  renderGroups();
  rebuildTopicChips();
  renderInsertedList();

  const counter = document.getElementById('insertCounter');
  if (insertedPapers.length === 0) {
    counter.style.display = 'none';
  } else {
    document.getElementById('insertCountNum').textContent = insertedPapers.length;
  }
}

function renderInsertedList() {
  const wrap = document.getElementById('insertedPapers');
  const list = document.getElementById('insertedList');
  if (!insertedPapers.length) { wrap.style.display = 'none'; return; }
  wrap.style.display = 'block';
  list.innerHTML = insertedPapers.map(p => `
    <div class="inserted-paper-row">
      <div style="flex:1">
        <div style="font-weight:500;font-size:13px;color:var(--ink);margin-bottom:2px">${p.title || '(Untitled)'}</div>
